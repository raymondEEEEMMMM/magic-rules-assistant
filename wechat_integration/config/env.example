# 微信公众号配置
# 复制此文件为 .env 并填入实际值

# 公众号 AppID（公众号唯一标识）
# 获取路径：微信公众号后台 → 开发 → 开发设置 → 公众号设置 → 账号详情
WECHAT_APP_ID=wxbea6e8c9bb4667e7

# 公众号 AppSecret（开发者密码）
# 获取路径：微信公众号后台 → 开发 → 开发设置 → 公众号开发信息
# ⚠️ 只显示一次，请妥善保存
WECHAT_APP_SECRET=your_app_secret_here

# 微信公众号 Token（用于验证消息）
# 可自行设置，用于微信服务器验证
WECHAT_TOKEN=wx_mtg_rules_2024

# 消息加解密密钥（可选）
# 获取路径：微信公众号后台 → 开发 → 开发设置
WECHAT_ENCODING_AES_KEY=

# ============ 以下为云函数环境变量 ============

# 服务器 IP 白名单
# 获取路径：微信公众号后台 → 开发 → 开发设置 → 公众号开发信息 → IP白名单
# 添加服务器出口 IP 以允许调用微信 API
WECHAT_SERVER_IPS=223.104.72.244
