# mtgAsk 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# ==================== 微信配置 ====================
# 微信公众号配置（用于接收用户消息）
WECHAT_TOKEN=your_wechat_token_here
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# ==================== 数据库配置 ====================
# MySQL 数据库（云端使用外网地址）
MYSQL_HOST=your_mysql_host.tencentcdb.com
MYSQL_PORT=27987
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name

# ==================== AI 服务配置 ====================
# MiniMax API（用于 AI 裁判功能）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-Text-01

# ==================== OpenCLAW Gateway 配置 ====================
# 自建 AI Agent 服务器（可选，不配置则关闭 AI 裁判功能）
OPENCLAW_ENABLED=false
OPENCLAW_HOST=your_server_ip_here
OPENCLAW_PORT=19601
OPENCLAW_SSH_USER=openclaw
OPENCLAW_SSH_KEY_CONTENT=your_ssh_private_key_base64_here

# Agent 池配置
OPENCLAW_MAX_AGENTS=100
OPENCLAW_IDLE_TIMEOUT=30

# AI Judge 每日限制
AI_JUDGE_DAILY_LIMIT=10

# ==================== 本地开发 ====================
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_PATH=./data/magic_rules.db
LOG_DIR=./logs
