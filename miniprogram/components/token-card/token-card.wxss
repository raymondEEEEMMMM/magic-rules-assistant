.token-card {
  display: flex;
  flex-direction: column;
  background-color: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  box-shadow: var(--shadow-card);
  position: relative;
}
.token-card:active { opacity: 0.7; }
.token-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
}
.token-type {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: var(--space-1);
}
.token-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.token-color-dot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.token-color-dot.color-W { background: var(--color-white); border: 1rpx solid var(--border-default); }
.token-color-dot.color-U { background: var(--color-blue); }
.token-color-dot.color-B { background: var(--color-black); }
.token-color-dot.color-R { background: var(--color-red); }
.token-color-dot.color-G { background: var(--color-green); }
.token-color-dot.color-C { background: var(--bg-input); }