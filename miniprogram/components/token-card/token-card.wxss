/* components/token-card/token-card.wxss */
.token-card {
  width: 210rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border: 2rpx solid transparent;
}

.token-card:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 颜色边框 */
.token-card.color-W { border-color: rgba(0, 0, 0, 0.25); }
.token-card.color-U { border-color: rgba(0, 0, 0, 0.25); }
.token-card.color-B { border-color: rgba(0, 0, 0, 0.25); }
.token-card.color-R { border-color: rgba(0, 0, 0, 0.25); }
.token-card.color-G { border-color: rgba(0, 0, 0, 0.25); }
.token-card.color-C { border-color: rgba(0, 0, 0, 0.25); }

.token-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.token-name {
  font-size: 26rpx;
  color: #ffffff;
  text-align: center;
  margin-bottom: 8rpx;
}

.token-color-dot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.color-dot-W { background: #fff8dc; border: 1rpx solid rgba(0,0,0,0.2); }
.color-dot-U { background: #007ec7; }
.color-dot-B { background: #504943; }
.color-dot-R { background: #d3202a; }
.color-dot-G { background: #00733e; }
.color-dot-C { background: #a19d9b; }

/* 日间主题 */
.page-light .token-card {
  background: rgba(0, 0, 0, 0.06);
}

.page-light .token-name {
  color: #333;
}

.page-light .token-card.color-W { border-color: rgba(0, 0, 0, 0.35); }
.page-light .token-card.color-U { border-color: rgba(0, 0, 0, 0.35); }
.page-light .token-card.color-B { border-color: rgba(0, 0, 0, 0.35); }
.page-light .token-card.color-R { border-color: rgba(0, 0, 0, 0.35); }
.page-light .token-card.color-G { border-color: rgba(0, 0, 0, 0.35); }
.page-light .token-card.color-C { border-color: rgba(0, 0, 0, 0.35); }