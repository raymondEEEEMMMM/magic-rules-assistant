/* 全局主题样式 */
page {
  --theme-bg: #16213e;
  --theme-bg-secondary: #1a1a2e;
  --theme-text: #ffffff;
  --theme-text-secondary: rgba(255, 255, 255, 0.6);
  --theme-text-muted: rgba(255, 255, 255, 0.4);
  --theme-border: rgba(255, 255, 255, 0.1);
  --theme-accent: #ffd700;
  --theme-accent-secondary: #667eea;
  --theme-card-bg: rgba(255, 255, 255, 0.08);
  --theme-input-bg: rgba(255, 255, 255, 0.1);
  background-color: var(--theme-bg);
  color: var(--theme-text);
}

/* 日间主题 */
page.theme-light {
  --theme-bg: #f5f5f5;
  --theme-bg-secondary: #ffffff;
  --theme-text: #333333;
  --theme-text-secondary: #666666;
  --theme-text-muted: #999999;
  --theme-border: #e0e0e0;
  --theme-accent: #667eea;
  --theme-accent-secondary: #764ba2;
  --theme-card-bg: rgba(0, 0, 0, 0.05);
  --theme-input-bg: #f0f0f0;
}
