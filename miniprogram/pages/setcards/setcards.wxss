/* pages/setcards/setcards.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  padding: 0;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.view-toggle {
  font-size: 40rpx;
}

/* 系列信息头 */
.set-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.1);
}

.set-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.set-meta {
  flex: 1;
}

.set-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.set-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.card-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 筛选器 */
.filter-section {
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.1);
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filter-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.filter-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  width: auto;
}

.toggle-icon {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.reset-btn {
  font-size: 22rpx;
  color: #ffd700;
  padding: 4rpx 16rpx;
  border: 1rpx solid #ffd700;
  border-radius: 16rpx;
}

.filter-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.view-toggle {
  font-size: 22rpx;
  color: #667eea;
  padding: 4rpx 16rpx;
  border: 1rpx solid #667eea;
  border-radius: 16rpx;
}

.filter-content {
  margin-top: 16rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  border: 1rpx solid transparent;
  min-width: 56rpx;
}

.filter-chip.active {
  background: rgba(255, 215, 0, 0.2);
  border-color: #ffd700;
}

.mana-icon {
  width: 32rpx;
  height: 32rpx;
}

.rarity-chips .filter-chip {
  min-width: 100rpx;
  font-size: 20rpx;
}

.type-chips .filter-chip {
  min-width: 80rpx;
  font-size: 20rpx;
}

.rarity-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 4rpx;
}

.rarity-dot.common { background: #888; }
.rarity-dot.uncommon { background: #fff; }
.rarity-dot.rare { background: #ffd700; }
.rarity-dot.mythic { background: #ff8c00; }

/* 关键词异能 */
.keywords-section {
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.1);
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
}

.keywords-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-chip {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.3) 0%, rgba(233, 69, 96, 0.15) 100%);
  border: 1rpx solid rgba(233, 69, 96, 0.5);
  border-radius: 30rpx;
}

.keyword-text {
  font-size: 24rpx;
  color: #e94560;
}

/* 卡牌网格视图 - 3列 */
.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  padding: 10rpx;
}

.card-grid-item {
  position: relative;
  width: 100%;
  aspect-ratio: 5/7;
  background: #1a1a2e;
  border-radius: 6rpx;
  overflow: hidden;
}

.card-grid-image {
  width: 100%;
  height: 100%;
}

.card-grid-info {
  display: none;
}

.card-grid-name {
  font-size: 16rpx;
  color: #fff;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: center;
}

/* 卡牌列表视图 */
.card-list {
  padding: 20rpx;
}

.card-list-item {
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
}

.card-list-name {
  font-size: 28rpx;
  color: #fff;
}

.card-list-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-list-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.card-list-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.card-list-set {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-results-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.no-results-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== */
/* 卡牌详情页样式 */
/* ==================== */
.card-detail-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #16213e;
  z-index: 100;
}

.detail-image-container {
  width: 100%;
  height: 45vh;
  background: #0a0a1a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-image {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.detail-content {
  height: 55vh;
  padding: 30rpx;
  overflow-y: auto;
}

/* 名称区域 */
.detail-name-section {
  margin-bottom: 30rpx;
}

.detail-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
}

.copy-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 20rpx;
  border: 1rpx solid #667eea;
  border-radius: 30rpx;
}

.detail-en-name {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

/* 信息卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 140rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
}

.info-value.mana {
  display: flex;
  gap: 4rpx;
}

.rarity-common { color: #000; }
.rarity-uncommon { color: #fff; }
.rarity-rare { color: #ffd700; }
.rarity-mythic { color: #ff6b35; }

/* 规则文本 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 16rpx;
}

.oracle-card, .flavor-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 20rpx;
}

.oracle-card.en {
  border-left: 4rpx solid #667eea;
}

.oracle-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  white-space: pre-wrap;
}

.flavor-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-style: italic;
  line-height: 1.6;
}

/* ==================== */
/* 日间主题 (Light Mode) */
/* ==================== */
.container.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.container.page-light .nav-bar {
  background: #ffffff;
  border-bottom-color: #e0e0e0;
}

.container.page-light .back-btn {
  color: #667eea;
}

.container.page-light .nav-title {
  color: #333333;
}

.container.page-light .set-header {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-bottom-color: rgba(102, 126, 234, 0.2);
}

.container.page-light .set-name {
  color: #333333;
}

.container.page-light .set-date,
.container.page-light .card-count {
  color: rgba(0, 0, 0, 0.5);
}

.container.page-light .card-count {
  background: rgba(0, 0, 0, 0.05);
}

.container.page-light .filter-section {
  background: rgba(0, 0, 0, 0.03);
  border-bottom-color: rgba(102, 126, 234, 0.2);
}

.container.page-light .filter-label {
  color: #667eea;
}

.container.page-light .toggle-icon {
  color: rgba(102, 126, 234, 0.6);
}

.container.page-light .reset-btn {
  color: #667eea;
  border-color: #667eea;
}

.container.page-light .view-toggle {
  color: #ffd700;
  border-color: #ffd700;
}

.container.page-light .filter-chip {
  background: rgba(102, 126, 234, 0.1);
  color: #333;
}

.container.page-light .filter-chip.active {
  background: rgba(102, 126, 234, 0.2);
  border-color: #667eea;
}

.container.page-light .keywords-section {
  border-bottom-color: rgba(102, 126, 234, 0.2);
}

.container.page-light .section-title {
  color: #667eea;
}

.container.page-light .keyword-chip {
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.1) 0%, rgba(233, 69, 96, 0.05) 100%);
  border-color: rgba(233, 69, 96, 0.3);
}

.container.page-light .keyword-text {
  color: #e94560;
}

.container.page-light .card-grid-item {
  background: rgba(255, 255, 255, 0.95);
}

.container.page-light .card-grid-info {
  background: rgba(0, 0, 0, 0.7);
}

.container.page-light .card-grid-name {
  color: #ffffff;
}

.container.page-light .card-list-item {
  background: rgba(255, 255, 255, 0.95);
}

.container.page-light .card-list-name {
  color: #333333;
}

.container.page-light .card-list-type {
  color: rgba(0, 0, 0, 0.6);
}

.container.page-light .card-list-set {
  color: rgba(0, 0, 0, 0.4);
}

.container.page-light .no-results {
  background: #f5f5f5;
}

.container.page-light .no-results-text {
  color: #666666;
}

/* 详情页日间模式 */
.card-detail-page.page-light {
  background: #f5f5f5;
}

.card-detail-page.page-light .nav-bar {
  background: #ffffff;
  border-bottom-color: #e0e0e0;
}

.card-detail-page.page-light .nav-title {
  color: #333333;
}

.card-detail-page.page-light .back-btn {
  color: #667eea;
}

.card-detail-page.page-light .detail-content {
  background: #f5f5f5;
}

.card-detail-page.page-light .detail-name {
  color: #333333;
}

.card-detail-page.page-light .info-card {
  background: rgba(255, 255, 255, 0.95);
}

.card-detail-page.page-light .info-label {
  color: rgba(0, 0, 0, 0.5);
}

.card-detail-page.page-light .info-value {
  color: #333333;
}

.card-detail-page.page-light .oracle-card {
  background: rgba(255, 255, 255, 0.95);
}

.card-detail-page.page-light .oracle-text {
  color: #333333;
}

.card-detail-page.page-light .flavor-text {
  color: rgba(0, 0, 0, 0.5);
}
