<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">mtgAsk</text>
      <text class="banner-subtitle">万智牌规则问答助手</text>
    </view>
  </view>

  <!-- 搜索入口 -->
  <view class="search-box" bindtap="goToSearch">
    <view class="search-icon">🔍</view>
    <text class="search-placeholder">搜索规则、卡牌、关键词...</text>
  </view>

  <!-- 快速功能入口 -->
  <view class="quick-actions">
    <view class="section-title">快速入口</view>
    <view class="action-grid">
      <view class="action-card" bindtap="goToKeyword">
        <view class="action-icon">📖</view>
        <text class="action-text">关键词</text>
        <text class="action-desc">异能的规则解释</text>
      </view>
      <view class="action-card" bindtap="goToCard">
        <view class="action-icon">🃏</view>
        <text class="action-text">卡牌</text>
        <text class="action-desc">查询卡牌信息</text>
      </view>
      <view class="action-card" bindtap="goToSearch">
        <view class="action-icon">📜</view>
        <text class="action-text">规则</text>
        <text class="action-desc">游戏规则搜索</text>
      </view>
      <view class="action-card ai-judge-card" bindtap="goToAIJudge">
        <view class="action-icon">🤖</view>
        <text class="action-text">AI 裁判</text>
        <text class="action-desc">智能规则问答</text>
      </view>
    </view>
  </view>

  <!-- 热门关键词 -->
  <view class="hot-keywords">
    <view class="section-title">热门关键词</view>
    <view class="keyword-tags">
      <view class="keyword-tag" wx:for="{{hotKeywords}}" wx:key="index" bindtap="searchKeyword" data-keyword="{{item}}">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 随机卡牌 -->
  <view class="random-card" bindtap="showRandomCard">
    <view class="random-header">
      <text class="random-title">🎲 随机卡牌</text>
    </view>
    <view class="random-hint">点击获取一张随机卡牌</view>
  </view>

  <!-- API 测试入口 -->
  <view class="api-test-link" bindtap="goToAPITest">
    <text>🔧 API 测试</text>
  </view>
</view>
