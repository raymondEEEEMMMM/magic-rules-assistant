<!--pages/index/index.wxml-->
<view class="container {{isLightTheme ? 'page-light' : ''}}">
  <!-- 顶部Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">MTGAsk</text>
      <text class="banner-subtitle">万智牌规则问答助手</text>
    </view>
    <view class="theme-btn" bindtap="toggleTheme">{{isLightTheme ? '🌙' : '☀️'}}</view>
  </view>

  <!-- AI 裁判入口 -->
  <view class="ai-judge-section" bindtap="goToAIJudge">
    <view class="ai-judge-badge">
      <image class="ai-badge-icon" src="/images/mtgask_logo.png" mode="aspectFit"></image>
      <view class="ai-badge-glow"></view>
    </view>
    <view class="ai-judge-info">
      <text class="ai-judge-title">AI 裁判</text>
      <text class="ai-judge-desc">智能规则问答 · 随时随地</text>
    </view>
    <view class="ai-judge-arrow">›</view>
  </view>

  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="异能关键词、卡牌、规则编号..."
        placeholder-class="search-placeholder"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
        value="{{keyword}}"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">
        <text>✕</text>
      </view>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!keyword && history.length > 0}}">
    <view class="history-header">
      <text class="history-title">历史记录</text>
      <text class="history-clear" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view
        class="history-item"
        wx:for="{{history}}"
        wx:key="index"
        bindtap="useHistory"
        data-keyword="{{item}}"
      >
        <text class="history-icon">🕐</text>
        <text class="history-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 生命值计数器入口 -->
  <view class="counter-entry" wx:if="{{!keyword}}" bindtap="goToCounter">
    <view class="counter-icon">❤️</view>
    <view class="counter-info">
      <text class="counter-title">生命值计数器</text>
      <text class="counter-desc">指挥官 · 2-4人游戏</text>
    </view>
    <view class="counter-arrow">›</view>
  </view>

  <!-- 最新系列资讯 -->
  <view class="latest-sets" wx:if="{{latestSets.length > 0 && !keyword}}">
    <view class="sets-header">
      <text class="new-tag">New</text>
      <text class="sets-title">最新系列</text>
    </view>
    <scroll-view class="sets-scroll" scroll-x enable-flex>
      <view class="sets-list">
        <view class="set-item" wx:for="{{latestSets}}" wx:key="code" bindtap="viewSetCards" data-code="{{item.code}}" data-name="{{item.name}}">
          <image class="set-icon" src="{{item.iconUrl}}" mode="aspectFit" />
          <text class="set-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Secret Lair 资讯 -->
  <view class="sld-section" wx:if="{{showSldSection && !keyword}}">
    <view class="sets-header" bindtap="goToSldCards">
      <view class="sld-header-left">
        <text class="new-tag sld-tag">SLD</text>
        <text class="sets-title">Secret Lair 专区</text>
      </view>
      <text class="sld-more">查看全部 ›</text>
    </view>
    <scroll-view class="sld-scroll" scroll-x enable-flex>
      <view class="sld-list">
        <view class="sld-group" wx:for="{{sldGroups}}" wx:key="date">
          <view class="sld-date">{{item.date}}</view>
          <view class="sld-cards">
            <view class="sld-card" wx:for="{{item.cards}}" wx:for-item="card" wx:key="id" bindtap="viewCardDetail" data-id="{{card.id}}">
              <image class="sld-card-image" src="{{card.image_url}}" mode="aspectFill" />
              <text class="sld-card-name">{{card.name}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 组合搜索结果 -->
  <view class="combined-results" wx:if="{{keyword && searchDone}}">
    <!-- 关键词结果 -->
    <view class="result-section" wx:if="{{combinedResults.keywords.length > 0}}">
      <view class="section-header">
        <view class="section-bar keyword-bar">
          <text class="section-title">关键词异能</text>
        </view>
        <text class="section-count">{{combinedResults.keywords.length}}</text>
      </view>
      <view class="result-list">
        <view class="result-card keyword-card" wx:for="{{combinedResults.keywords}}" wx:key="index" bindtap="viewKeywordDetail" data-keyword="{{item.keyword_name}}">
          <view class="result-header">
            <text class="result-number">{{item.keyword_en}}</text>
            <text class="result-title">{{item.keyword_name}}</text>
          </view>
          <text class="result-content">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 卡牌结果 -->
    <view class="result-section" wx:if="{{combinedResults.cards.length > 0}}">
      <view class="section-header">
        <view class="section-bar card-bar">
          <text class="section-title">卡牌</text>
        </view>
        <text class="section-count">{{combinedResults.cards.length}}</text>
      </view>
      <view class="result-list card-list">
        <view class="card-item" wx:for="{{combinedResults.cards}}" wx:key="index" bindtap="viewCardDetail" data-id="{{item.id}}">
          <view class="card-name">{{item.zhs_name || item.name}}</view>
          <view class="card-type">{{item.type_line}}</view>
        </view>
        <!-- 查看更多 -->
        <view class="view-more-card" wx:if="{{combinedResults.cards.length >= 5}}" bindtap="viewMoreCards" data-keyword="{{keyword}}">
          <text class="view-more-text">查看更多卡牌 →</text>
        </view>
      </view>
    </view>

    <!-- 规则结果 -->
    <view class="result-section" wx:if="{{combinedResults.rules.length > 0}}">
      <view class="section-header">
        <view class="section-bar rule-bar">
          <text class="section-title">规则</text>
        </view>
        <text class="section-count">{{combinedResults.rules.length}}</text>
      </view>
      <view class="result-list">
        <view class="result-card" wx:for="{{combinedResults.rules}}" wx:key="index" bindtap="viewRuleDetail" data-rule="{{item.rule_number}}">
          <view class="result-header">
            <text class="result-number">{{item.rule_number}}</text>
            <text class="result-title">{{item.rule_title}}</text>
          </view>
          <text class="result-content">{{item.rule_content}}</text>
        </view>
      </view>
    </view>

    <!-- 无结果 -->
    <view class="no-results" wx:if="{{combinedResults.keywords.length === 0 && combinedResults.cards.length === 0 && combinedResults.rules.length === 0}}">
      <text class="no-results-icon">🔎</text>
      <text class="no-results-text">未找到与「{{keyword}}」相关的内容</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">v{{version}}</text>
    <text class="version-divider">·</text>
    <text class="feedback-link" bindtap="goToFeedback">意见反馈</text>
  </view>
</view>
