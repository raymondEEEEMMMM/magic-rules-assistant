/* pages/index/index.wxss */
page { background-color: var(--bg-page); color: var(--text-primary); }
.container { min-height: 100vh; padding: 0; display: flex; flex-direction: column; }

/* Brand */
.brand-section { padding: 60rpx 40rpx 40rpx; padding-top: calc(60rpx + env(safe-area-inset-top)); text-align: center; background: var(--bg-page); }
.brand-content { display: flex; flex-direction: column; align-items: center; }
.brand-title { display: block; font-size: 56rpx; font-weight: 700; color: var(--text-primary); letter-spacing: -1rpx; }
.brand-subtitle { display: block; font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

/* AI Banner */
.ai-banner { margin: 24rpx 32rpx; background: var(--accent-dark); color: var(--text-inverse); border-radius: 20rpx; padding: 24rpx; display: flex; align-items: center; gap: 20rpx; box-shadow: var(--shadow-card); }
.ai-banner:active { opacity: 0.9; }
.ai-icon-block { width: 72rpx; height: 72rpx; background: var(--accent-gold); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ai-icon { width: 40rpx; height: 40rpx; }
.ai-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.ai-title { font-size: 32rpx; font-weight: 600; color: var(--text-inverse); }
.ai-desc { font-size: 22rpx; color: rgba(255, 255, 255, 0.7); }
.ai-arrow { font-size: 40rpx; color: rgba(255, 255, 255, 0.5); margin-left: auto; }

/* Search Card */
.search-card { margin: 24rpx 32rpx; background: var(--bg-card); border-radius: 24rpx; box-shadow: var(--shadow-card); padding: 16rpx 20rpx; display: flex; align-items: center; gap: 16rpx; }
.search-row { flex: 1; display: flex; align-items: center; background: var(--bg-input); border-radius: 20rpx; padding: 16rpx 20rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.5; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.search-placeholder { color: var(--text-muted); }
.search-clear { padding: 8rpx; color: var(--text-muted); }
.search-btn { background: var(--accent-dark); color: var(--text-inverse); border-radius: 20rpx; padding: 16rpx 32rpx; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; }
.search-btn:active { opacity: 0.7; }

/* Tools Section */
.tools-section { margin: 32rpx; }
.section-title-wrap { padding: 0 8rpx 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.tools-card { background: var(--bg-card); border-radius: 20rpx; box-shadow: var(--shadow-card); overflow: hidden; }
.tool-item { display: flex; align-items: center; gap: 24rpx; padding: 28rpx 24rpx; }
.tool-item:active { background: var(--bg-input); }
.tool-divider { height: 1rpx; background: var(--border-subtle); margin: 0 24rpx; }
.tool-icon-block { width: 68rpx; height: 68rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.tool-color-blue { background-color: var(--color-blue); }
.tool-color-black { background-color: var(--color-black); }
.tool-color-red { background-color: var(--color-red); }
.tool-color-green { background-color: var(--color-green); }
.tool-icon { width: 36rpx; height: 36rpx; }
.tool-icon-bg {
  background-size: 36rpx 36rpx;
  background-position: center;
  background-repeat: no-repeat;
}
.tool-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.tool-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.tool-desc { font-size: 22rpx; color: var(--text-secondary); }
.tool-chevron {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
  flex-shrink: 0;
  background-size: 32rpx 32rpx;
  background-position: center;
  background-repeat: no-repeat;
  background-color: transparent;
}

/* Search History */
.search-history { padding: 0 30rpx 20rpx; }
.history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.history-title { font-size: 28rpx; color: var(--text-secondary); }
.history-clear { font-size: 24rpx; color: var(--accent-dark); }
.history-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.history-item { display: flex; align-items: center; padding: 12rpx 24rpx; background: var(--bg-input); border-radius: 30rpx; gap: 12rpx; }
.history-icon { width: 24rpx; height: 24rpx; opacity: 0.6; background-size: contain; background-position: center; background-repeat: no-repeat; flex-shrink: 0; }
.history-text { font-size: 26rpx; color: var(--text-primary); }

/* Latest Sets */
.latest-sets { padding: 20rpx 30rpx 30rpx; }
.sets-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.sld-header-left { display: flex; align-items: center; }
.new-tag { background: #e63946; color: #fff; font-size: 20rpx; font-weight: bold; padding: 4rpx 12rpx; border-radius: 6rpx; margin-right: 12rpx; }
.sets-title { font-size: 28rpx; color: var(--text-primary); }
.sld-more { font-size: 24rpx; color: #9b59b6; }
.sets-scroll { white-space: nowrap; }
.sets-list { display: inline-flex; gap: 20rpx; background: var(--bg-input); border-radius: 16rpx; padding: 20rpx; }
.set-item { display: flex; flex-direction: column; align-items: center; min-width: 120rpx; }
.set-icon { width: 60rpx; height: 60rpx; margin-bottom: 10rpx; }
.set-name { font-size: 22rpx; color: var(--text-primary); text-align: center; max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Secret Lair */
.sld-section { padding: 20rpx 30rpx 30rpx; }
.sld-tag { background: #9b59b6; }
.sld-scroll { white-space: nowrap; }
.sld-list { display: inline-flex; gap: 30rpx; background: var(--bg-input); border-radius: 16rpx; padding: 20rpx; }
.sld-group { display: flex; flex-direction: column; min-width: 280rpx; }
.sld-date { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 16rpx; padding-bottom: 12rpx; border-bottom: 1rpx solid var(--border-subtle); }
.sld-cards { display: flex; gap: 16rpx; }
.sld-card { display: flex; flex-direction: column; align-items: center; min-width: 100rpx; }
.sld-card-image { width: 80rpx; height: 112rpx; border-radius: 8rpx; background: var(--bg-input); margin-bottom: 8rpx; }
.sld-card-name { font-size: 20rpx; color: var(--text-primary); text-align: center; max-width: 100rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Promo Entry (P5 升级：用 SVG 替代 emoji，对齐新设计系统) */
.promo-entry { display: flex; align-items: center; gap: 20rpx; margin: 24rpx 32rpx; background: var(--bg-card); border-radius: 20rpx; padding: 24rpx; box-shadow: var(--shadow-card); }
.promo-entry:active { opacity: 0.9; }
.promo-icon-block { width: 72rpx; height: 72rpx; background: #9370db; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.promo-icon-bg { width: 40rpx; height: 40rpx; background-size: contain; background-position: center; background-repeat: no-repeat; }
.promo-info { flex: 1; min-width: 0; }
.promo-title { display: block; font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.promo-desc { display: block; font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.promo-arrow { font-size: 40rpx; color: var(--text-muted); font-weight: 300; }

/* Search Results */
.combined-results { padding: 0 30rpx 20rpx; }
.result-section { margin-bottom: 40rpx; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; padding: 0 4rpx; }
.section-bar { padding: 12rpx 0; padding-left: 20rpx; border-left: 6rpx solid; }
.keyword-bar { border-left-color: #e94560; }
.card-bar { border-left-color: var(--accent-dark); }
.rule-bar { border-left-color: #ffd700; }
.section-count { font-size: 24rpx; color: var(--text-secondary); background: var(--bg-input); padding: 6rpx 20rpx; border-radius: 20rpx; }
.section-more { font-size: 24rpx; color: var(--accent-dark); padding: 6rpx 0; margin-left: 16rpx; }
.result-list { display: flex; flex-direction: column; gap: 20rpx; }
.result-card { background: var(--bg-card); border-radius: 20rpx; padding: 24rpx; border-left: 6rpx solid var(--accent-dark); box-shadow: var(--shadow-card); }
.result-card.keyword-card { border-left-color: #e94560; }
.result-header { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 12rpx; }
.result-number { font-size: 24rpx; color: var(--accent-dark); font-weight: bold; }
.result-title { font-size: 30rpx; color: var(--text-primary); font-weight: bold; }
.result-content { display: -webkit-box; font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; overflow: hidden; text-overflow: ellipsis; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.card-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.card-item { background: var(--bg-card); border-radius: 16rpx; padding: 20rpx; box-shadow: var(--shadow-card); }
.card-name { font-size: 28rpx; font-weight: bold; color: var(--text-primary); margin-bottom: 8rpx; }
.card-type { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; }

/* No Results */
.no-results { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100rpx 0; }
.no-results-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.5; }
.no-results-text { font-size: 28rpx; color: var(--text-secondary); }

/* Version Info */
.version-info { margin-top: auto; padding: 30rpx; text-align: center; display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.version-text { font-size: 24rpx; color: var(--text-muted); }
.version-divider { font-size: 24rpx; color: var(--text-muted); }
