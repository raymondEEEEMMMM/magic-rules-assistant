  border: 2rpx solid rgba(74, 222, 128, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(74, 222, 128, 0.15);
}

.counter-entry:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.counter-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
}

.counter-info {
  flex: 1;
}

.counter-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.counter-desc {
