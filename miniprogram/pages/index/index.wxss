/* pages/index/index.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  padding: 0;
  display: flex;
  flex-direction: column;
}

/* Banner */
.banner {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 100rpx 40rpx 60rpx;
  padding-top: calc(100rpx + env(safe-area-inset-top));
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
  text-align: center;
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-title {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
}

/* 主题切换按钮 */
.theme-btn {
  position: absolute;
  top: calc(40rpx + env(safe-area-inset-top));
  left: 40rpx;
  font-size: 44rpx;
  padding: 10rpx;
}

/* 搜索框 */
.search-box {
  display: flex;
  gap: 20rpx;
  margin: 30rpx;
  margin-top: 10rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.search-clear {
  padding: 10rpx;
  color: rgba(255, 255, 255, 0.5);
}

.search-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  color: #fff;
  display: flex;
  align-items: center;
}

/* 搜索历史 */
.search-history {
  padding: 0 30rpx 20rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.history-clear {
  font-size: 24rpx;
  color: #667eea;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  gap: 12rpx;
}

.history-icon {
  font-size: 24rpx;
  opacity: 0.5;
}

.history-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 组合结果 */
.combined-results {
  padding: 0 30rpx 20rpx;
}

.result-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-bar {
  padding: 12rpx 0;
  padding-left: 20rpx;
  border-left: 6rpx solid;
}

.keyword-bar {
  border-left-color: #e94560;
}

.card-bar {
  border-left-color: #667eea;
}

.rule-bar {
  border-left-color: #ffd700;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.section-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  border-left: 6rpx solid #667eea;
}

.result-card.keyword-card {
  border-left-color: #e94560;
}

.result-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.result-number {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

.result-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

.result-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 卡牌列表 */
.card-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.card-item {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.card-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-results-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.no-results-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* AI 裁判入口 */
.ai-judge-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #2d1f4e 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 30rpx 30rpx 40rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.25);
  position: relative;
  overflow: hidden;
}

.ai-judge-section:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.ai-judge-badge {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
}

.ai-badge-icon {
  width: 72rpx;
  height: 72rpx;
  z-index: 2;
  animation: float 3s ease-in-out infinite;
}

.ai-badge-glow {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  background: radial-gradient(circle, rgba(147, 112, 219, 0.6) 0%, transparent 70%);
  border-radius: 50%;
  animation: glow-pulse 2s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

@keyframes glow-pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.2); opacity: 1; }
}

.ai-judge-info {
  flex: 1;
}

.ai-judge-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.ai-judge-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.ai-judge-arrow {
  font-size: 48rpx;
  color: rgba(147, 112, 219, 0.6);
  font-weight: 300;
}

/* 生命值计数器入口 */
.counter-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1f4e3d 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 20rpx 30rpx 30rpx;
  border: 2rpx solid rgba(74, 222, 128, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(74, 222, 128, 0.15);
}

.counter-entry:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.counter-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
}

.counter-info {
  flex: 1;
}

.counter-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.counter-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.counter-arrow {
  font-size: 48rpx;
  color: rgba(74, 222, 128, 0.6);
  font-weight: 300;
}

/* 版本信息 */
.version-info {
  margin-top: auto;
  padding: 30rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.version-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.version-divider {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.feedback-link {
  font-size: 24rpx;
  color: rgba(102, 126, 234, 0.8);
}

/* ==================== */
/* 日间主题 (Light Mode) */
