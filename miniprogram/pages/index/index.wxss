.container.page-light .sld-card-image {
  background: rgba(0, 0, 0, 0.05);
}

.container.page-light .sld-card-name {
  color: #666;
}

.container.page-light .sld-more {
  color: #9b59b6;
}

.container.page-light .version-text {
  color: rgba(0, 0, 0, 0.4);
}

.container.page-light .version-divider {
  color: rgba(0, 0, 0, 0.4);
}

.container.page-light .feedback-link {
  color: var(--legacy-accent-start);
}

/* ==================== */
/* Promo 卡快讯入口 */
/* ==================== */
.promo-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #2a1f3d 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 20rpx 30rpx 30rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.15);
}

.promo-entry:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.promo-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
}

.promo-info {
  flex: 1;
}

.promo-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.promo-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.promo-arrow {
  font-size: 48rpx;
  color: rgba(147, 112, 219, 0.6);
  font-weight: 300;
}

/* 日间主题 - Promo 入口 */
.container.page-light .promo-entry {
  background: linear-gradient(135deg, #f5f0ff 0%, #ffffff 100%);
  border-color: rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.1);
}

.container.page-light .promo-title {
  color: #9370db;
}

.container.page-light .promo-desc {
  color: #999;
}

.container.page-light .promo-arrow {
  color: rgba(147, 112, 219, 0.5);
}
