/* pages/index/index.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  padding: 0 30rpx 40rpx;
}

/* Banner */
.banner {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
  margin: 0 -30rpx 40rpx;
}

.banner-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
}

/* 搜索框 */
.search-box {
  margin: -20rpx 30rpx 40rpx;
  background: white;
  border-radius: 50rpx;
  padding: 24rpx 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
}

.search-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

/* 快速入口 */
.quick-actions {
  margin-bottom: 40rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.action-card {
  width: calc(33.33% - 14rpx);
  background: linear-gradient(145deg, #1f2b4d 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  transition: all 0.3s ease;
  box-sizing: border-box;
}

/* AI 裁判卡片 */
.ai-judge-card {
  background: linear-gradient(145deg, #2d1f4e 0%, #1a1a2e 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.2);
}

.ai-judge-card .action-icon {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.action-card:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.action-text {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 热门关键词 */
.hot-keywords {
  margin-bottom: 40rpx;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keyword-tag {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: white;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.keyword-tag:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 随机卡牌 */
.random-card {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(245, 87, 108, 0.3);
}

.random-card:active {
  transform: scale(0.98);
}

.random-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 16rpx;
}

.random-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* API 测试链接 */
.api-test-link {
  margin-top: 30rpx;
  text-align: center;
  color: #666;
  font-size: 28rpx;
  padding: 20rpx;
}
