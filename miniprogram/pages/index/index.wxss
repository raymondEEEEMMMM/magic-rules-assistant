/* pages/index/index.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  padding: 0 30rpx 40rpx;
}

/* Banner区域 */
.banner {
  position: relative;
  height: 320rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
  margin: 0 -30rpx 40rpx;
}

.banner-content {
  position: relative;
  z-index: 2;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 4rpx 20rpx rgba(233, 69, 96, 0.5);
  letter-spacing: 4rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

.banner-decoration {
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(233, 69, 96, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

/* 快速入口 */
.quick-actions {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e94560;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.action-card {
  background: linear-gradient(145deg, #1f2b4d 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(233, 69, 96, 0.2);
  transition: all 0.3s ease;
}

.action-card:active {
  transform: scale(0.96);
  background: linear-gradient(145deg, #2a3a5d 0%, #1f2b4d 100%);
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.action-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.action-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 热门关键词 */
.hot-keywords {
  margin-bottom: 40rpx;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keyword-tag {
  padding: 16rpx 28rpx;
  background: rgba(233, 69, 96, 0.15);
  border: 1rpx solid rgba(233, 69, 96, 0.3);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #e94560;
  transition: all 0.3s ease;
}

.keyword-tag:active {
  background: rgba(233, 69, 96, 0.3);
  transform: scale(0.95);
}

/* 每日卡牌 */
.daily-card {
  background: linear-gradient(145deg, #1f2b4d 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

.daily-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.daily-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffd700;
}

.daily-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
}

/* 功能说明 */
.features {
  margin-bottom: 40rpx;
}

.feature-list {
  background: rgba(26, 26, 46, 0.6);
  border-radius: 24rpx;
  overflow: hidden;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.feature-content {
  flex: 1;
}

.feature-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
  display: block;
}

/* 测试工具 */
.test-tools {
  margin-bottom: 40rpx;
}

.test-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.test-card {
  background: linear-gradient(145deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.test-card:active {
  transform: scale(0.96);
  background: linear-gradient(145deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
}

.test-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.test-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
}

.test-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  text-align: center;
}
