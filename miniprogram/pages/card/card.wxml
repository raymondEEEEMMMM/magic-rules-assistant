<!--pages/card/card.wxml-->
<wxs module="utils">
module.exports = {
  includes: function(arr, item) {
    return arr.indexOf(item) !== -1
  }
}
</wxs>
<view class="container {{isLightTheme ? '' : 'theme-dark'}}">
  <!-- 导航栏 -->
  <view class="nav-bar {{isLightTheme ? 'nav-bar-light' : ''}}">
    <view class="nav-left">
      <view class="back-btn" bindtap="goToIndex">
        <view class="back-icon icon-bg-home"></view>
      </view>
    </view>
    <view class="nav-title">
      <text>{{keyword || '卡牌查询'}}</text>
    </view>
    <view class="nav-right">
      <view class="view-toggle" bindtap="toggleView" wx:if="{{filteredCards.length > 0}}">
        <text>{{viewMode === 'image' ? '列表' : '图片'}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选器 -->
  <view class="filter-section">
    <view class="filter-header">
      <view class="filter-title" bindtap="toggleFilter">
        <text class="filter-label">筛选</text>
        <text class="toggle-icon">{{showFilter ? '▼' : '▶'}}</text>
      </view>
      <view class="filter-actions">
        <view class="reset-btn" bindtap="resetFilters" wx:if="{{filterColor.length > 0 || filterCmc || filterType || filterRarity}}">
          <text>重置</text>
        </view>
      </view>
    </view>

    <!-- 筛选内容 -->
    <view class="filter-content" wx:if="{{showFilter}}">
      <!-- 类别筛选 -->
      <view class="filter-row">
        <text class="filter-label">类别</text>
        <view class="filter-chips type-chips">
          <view class="filter-chip {{filterType === 'Creature' ? 'active' : ''}}" bindtap="onTypeFilter" data-type="Creature">生物</view>
          <view class="filter-chip {{filterType === 'Artifact' ? 'active' : ''}}" bindtap="onTypeFilter" data-type="Artifact">神器</view>
          <view class="filter-chip {{filterType === 'Instant' ? 'active' : ''}}" bindtap="onTypeFilter" data-type="Instant">法术</view>
          <view class="filter-chip {{filterType === 'Land' ? 'active' : ''}}" bindtap="onTypeFilter" data-type="Land">地</view>
          <view class="filter-chip {{filterType === 'Enchantment' ? 'active' : ''}}" bindtap="onTypeFilter" data-type="Enchantment">结界</view>
        </view>
      </view>

      <!-- 颜色筛选（多选） -->
      <view class="filter-row">
        <text class="filter-label">颜色</text>
        <view class="filter-chips">
          <view class="filter-chip {{utils.includes(filterColor, 'W') ? 'active' : ''}}" bindtap="onColorFilter" data-color="W">
            <image class="mana-icon" src="https://svgs.scryfall.io/card-symbols/W.svg" />
          </view>
          <view class="filter-chip {{utils.includes(filterColor, 'U') ? 'active' : ''}}" bindtap="onColorFilter" data-color="U">
            <image class="mana-icon" src="https://svgs.scryfall.io/card-symbols/U.svg" />
          </view>
          <view class="filter-chip {{utils.includes(filterColor, 'B') ? 'active' : ''}}" bindtap="onColorFilter" data-color="B">
            <image class="mana-icon" src="https://svgs.scryfall.io/card-symbols/B.svg" />
          </view>
          <view class="filter-chip {{utils.includes(filterColor, 'R') ? 'active' : ''}}" bindtap="onColorFilter" data-color="R">
            <image class="mana-icon" src="https://svgs.scryfall.io/card-symbols/R.svg" />
          </view>
          <view class="filter-chip {{utils.includes(filterColor, 'G') ? 'active' : ''}}" bindtap="onColorFilter" data-color="G">
            <image class="mana-icon" src="https://svgs.scryfall.io/card-symbols/G.svg" />
          </view>
        </view>
      </view>

      <!-- 法力值筛选 -->
      <view class="filter-row">
        <text class="filter-label">费用</text>
        <view class="filter-chips">
          <view class="filter-chip {{filterCmc === '0' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="0">0</view>
          <view class="filter-chip {{filterCmc === '1' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="1">1</view>
          <view class="filter-chip {{filterCmc === '2' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="2">2</view>
          <view class="filter-chip {{filterCmc === '3' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="3">3</view>
          <view class="filter-chip {{filterCmc === '4' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="4">4</view>
          <view class="filter-chip {{filterCmc === '5' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="5">5</view>
          <view class="filter-chip {{filterCmc === '6+' ? 'active' : ''}}" bindtap="onCmcFilter" data-cmc="6+">6+</view>
        </view>
      </view>

      <!-- 稀有度筛选 -->
      <view class="filter-row">
        <text class="filter-label">稀有度</text>
        <view class="filter-chips rarity-chips">
          <view class="filter-chip {{filterRarity === 'common' ? 'active' : ''}}" bindtap="onRarityFilter" data-rarity="common">Common</view>
          <view class="filter-chip {{filterRarity === 'uncommon' ? 'active' : ''}}" bindtap="onRarityFilter" data-rarity="uncommon">Uncommon</view>
          <view class="filter-chip {{filterRarity === 'rare' ? 'active' : ''}}" bindtap="onRarityFilter" data-rarity="rare">Rare</view>
          <view class="filter-chip {{filterRarity === 'mythic' ? 'active' : ''}}" bindtap="onRarityFilter" data-rarity="mythic">Mythic</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索结果统计 -->
  <view class="result-stats" wx:if="{{searchDone && filteredCards.length > 0}}">
    <text class="stats-text">共找到 {{totalCards}} 张卡牌，显示 {{filteredCards.length}} 张</text>
  </view>

  <!-- 卡牌网格视图 (3列) -->
  <view class="card-grid" wx:if="{{viewMode === 'image' && filteredCards.length > 0}}">
    <view
      class="card-grid-item"
      wx:for="{{filteredCards}}"
      wx:key="id"
      bindtap="showCardDetail"
      data-card="{{item}}"
    >
      <image
        class="card-grid-image"
        src="{{item.imageUrl || 'https://via.placeholder.com/150x210/1a1a2e/e94560?text=' + item.name}}"
        mode="aspectFill"
        lazy-load
      />
      <text class="card-grid-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 卡牌列表视图 -->
  <view class="card-list" wx:if="{{viewMode === 'text' && filteredCards.length > 0}}">
    <view
      class="card-list-item"
      wx:for="{{filteredCards}}"
      wx:key="id"
      bindtap="showCardDetail"
      data-card="{{item}}"
    >
      <text class="card-list-name">{{item.name}}</text>
      <text class="card-list-type">{{item.type}}</text>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
    <view class="loading-more-btn" wx:if="{{!loadingMore}}">
      <text class="load-more-text">加载更多</text>
    </view>
    <view class="loading-more-spinner" wx:if="{{loadingMore}}">
      <view class="spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 无结果 -->
  <view class="no-results" wx:if="{{searchDone && filteredCards.length === 0 && cards.length === 0 && keyword}}">
    <view class="no-results-icon icon-bg-card"></view>
    <text class="no-results-text">未找到卡牌「{{keyword}}」</text>
  </view>

  <!-- 筛选无结果 -->
  <view class="no-results" wx:if="{{searchDone && filteredCards.length === 0 && cards.length > 0}}">
    <text class="no-results-text">没有符合条件的卡牌</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="error-state">
    <empty-state icon="search" title="加载失败" desc="{{error}}" actionText="重试" bindaction="onRetry" />
  </view>

  <view wx:elif="{{!currentCard}}" class="empty-state-wrap">
    <empty-state icon="search" title="未找到卡牌" />
  </view>

  <view wx:else class="card-content">
    <view class="card-image-card">
      <image
        wx:if="{{currentCard.image_uris && currentCard.image_uris.normal}}"
        class="card-image"
        src="{{currentCard.image_uris.normal}}"
        mode="aspectFit"
      />
      <view wx:else class="card-image-placeholder">
        <text>无图片</text>
      </view>
    </view>

    <view class="card-header">
      <text class="card-name">{{currentCard.zhs_name || currentCard.name}}</text>
      <text wx:if="{{currentCard.name && currentCard.zhs_name && currentCard.name !== currentCard.zhs_name}}" class="card-name-en">{{currentCard.name}}</text>
      <text wx:if="{{currentCard.mana_cost}}" class="card-mana">{{currentCard.mana_cost}}</text>
    </view>

    <view class="card-tags">
      <tag-chip wx:if="{{currentCard.type_line}}" text="{{currentCard.type_line}}" />
      <tag-chip wx:if="{{currentCard.rarity}}" text="{{currentCard.rarity}}" color="var(--accent-gold)" />
    </view>

    <view class="card-body">
      <view wx:if="{{currentCard.oracle_text}}" class="card-text">
        <text>{{currentCard.oracle_text}}</text>
      </view>
      <view wx:if="{{currentCard.flavor_text}}" class="card-flavor">
        <text>{{currentCard.flavor_text}}</text>
      </view>
      <view wx:if="{{currentCard.power !== undefined && currentCard.power !== null}}" class="card-stats">
        <text class="stats-value">{{currentCard.power}}/{{currentCard.toughness}}</text>
      </view>
    </view>

    <!-- Oracle 规则文本 -->
    <view class="section" wx:if="{{currentCard.text}}">
      <text class="section-title">规则文本</text>
      <view class="oracle-card">
        <block wx:for="{{currentCard.textSegments}}" wx:key="index">
          <image wx:if="{{item.type === 'mana'}}" class="oracle-mana-symbol" src="{{item.url}}" mode="aspectFit" />
          <text wx:else class="oracle-text">{{item.text}}</text>
        </block>
      </view>
    </view>

    <!-- 英文 Oracle -->
    <view class="section en" wx:if="{{currentCard.enText && currentCard.enText !== currentCard.text}}">
      <text class="section-title">English Oracle</text>
      <view class="oracle-card en">
        <block wx:for="{{currentCard.enTextSegments}}" wx:key="index">
          <image wx:if="{{item.type === 'mana'}}" class="oracle-mana-symbol" src="{{item.url}}" mode="aspectFit" />
          <text wx:else class="oracle-text">{{item.text}}</text>
        </block>
      </view>
    </view>

    <!-- 官方裁定 -->
    <view class="section" wx:if="{{currentCard.rulings && currentCard.rulings.length > 0}}">
      <text class="section-title">官方裁定</text>
      <view class="rulings-list">
        <view class="ruling-item" wx:for="{{currentCard.rulings}}" wx:key="index">
          <text class="ruling-date">{{item.published_at}}</text>
          <text class="ruling-text">{{item.comment}}</text>
        </view>
      </view>

    <view class="card-actions">
      <view class="action-btn" bindtap="onShare">分享</view>
      <view class="action-btn" bindtap="onCopyName">复制牌名</view>
    </view>
  </view>
</view>