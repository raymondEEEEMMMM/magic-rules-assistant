/* pages/card/card.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #1f2b4d;
  border-radius: 50rpx;
  padding: 20rpx 28rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.2);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.search-btn {
  padding: 20rpx 36rpx;
  background: linear-gradient(135deg, #ffd700 0%, #daa520 100%);
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

/* 卡牌列表 */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-item {
  display: flex;
  background: rgba(31, 43, 77, 0.6);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 215, 0, 0.1);
}

.card-image {
  width: 160rpx;
  height: 224rpx;
  border-radius: 16rpx;
  margin: 16rpx;
}

.card-info {
  flex: 1;
  padding: 16rpx 16rpx 16rpx 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 8rpx;
}

.card-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-mana {
  font-size: 28rpx;
  color: #87ceeb;
}

.card-rarity {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  text-transform: uppercase;
}

.card-rarity.C {
  background: rgba(128, 128, 128, 0.3);
  color: #a0a0a0;
}

.card-rarity.U {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.card-rarity.R {
  background: rgba(255, 165, 0, 0.3);
  color: #ffa500;
}

.card-rarity.M {
  background: rgba(255, 215, 0, 0.3);
  color: #ffd700;
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.no-results-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.no-results-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
}

.no-results-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 16rpx;
}

/* 初始提示 */
.init-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.hint-icon {
  font-size: 80rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.hint-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
}

.hint-examples {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 20rpx;
  text-align: center;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 215, 0, 0.2);
  border-top-color: #ffd700;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 卡牌详情弹窗 */
.card-detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.detail-content {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 30rpx;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
}

.detail-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  z-index: 10;
}

.detail-image {
  width: 100%;
  height: 400rpx;
  border-radius: 30rpx 30rpx 0 0;
}

.detail-info {
  padding: 30rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  display: block;
}

.detail-name-en {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.detail-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.detail-value {
  font-size: 26rpx;
  color: #fff;
}

.detail-section {
  margin-top: 20rpx;
}

.detail-section-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 10rpx;
}

.detail-oracle {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
  display: block;
}

.detail-flavor {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-style: italic;
  line-height: 1.6;
  display: block;
}
