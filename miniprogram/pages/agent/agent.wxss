/* pages/agent/agent.wxss */
page {
  background-color: #16213e;
  height: 100%;
  color: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: right;
}

.theme-toggle {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.nav-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ai-badge {
  font-size: 36rpx;
}

.nav-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 欢迎区域 - 模拟AI消息样式 */
.welcome-wrapper {
  padding: 30rpx 0;
}

.welcome-ai {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  max-width: 85%;
}

.welcome-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700 0%, #daa520 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.welcome-bubble {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  border-bottom-left-radius: 10rpx;
  padding: 28rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.welcome-greeting {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.welcome-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.welcome-examples {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.example-item {
  background: rgba(102, 126, 234, 0.1);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #667eea;
}

/* 消息列表 */
.message-list {
  flex: 1;
  height: 0;
  padding: 30rpx;
  box-sizing: border-box;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.message {
  margin-bottom: 36rpx;
}

.message-main {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.message.user .message-main {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.user-avatar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.bot-avatar {
  background: linear-gradient(135deg, #ffd700 0%, #daa520 100%);
}

/* 气泡 */
.bubble {
  max-width: 75%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.7;
  word-wrap: break-word;
}

.bubble.user {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-bottom-right-radius: 10rpx;
}

.bubble.assistant {
  background: rgba(255, 255, 255, 0.95);
  color: #1a1a2e;
  border-bottom-left-radius: 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

/* AI 消息富文本样式 */
.bubble.assistant rich-text {
  color: #1a1a2e;
}

.bubble.assistant rich-text p {
  margin: 6rpx 0;
}

.bubble.assistant rich-text strong {
  font-weight: bold;
  color: #1a1a2e;
}

.bubble.assistant rich-text em {
  font-style: italic;
  color: #555;
}

.bubble.assistant rich-text h2 {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin: 12rpx 0 8rpx;
}

.bubble.assistant rich-text h3 {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin: 10rpx 0 6rpx;
}

.bubble.assistant rich-text ul,
.bubble.assistant rich-text ol {
  margin: 8rpx 0;
  padding-left: 32rpx;
}

.bubble.assistant rich-text li {
  margin: 4rpx 0;
}

/* 消息时间 */
.message-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 8rpx;
  padding-left: 80rpx;
}

.message.user .message-time {
  padding-left: 0;
  padding-right: 80rpx;
  text-align: right;
}

/* Loading */
.loading-bubble {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 140rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  border-bottom-left-radius: 10rpx;
  padding: 20rpx 28rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #667eea;
  animation: bounce 1.2s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.24s; }
.dot:nth-child(2) { animation-delay: -0.12s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* 输入区域 */
.input-area {
  flex-shrink: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #1a1a2e;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* 新建会话按钮栏 */
.new-session-bar {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 16rpx;
}

.new-session-btn {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  background: rgba(255, 215, 0, 0.15);
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.new-session-btn text {
  font-size: 26rpx;
  color: #ffd700;
}

/* 日间主题新建按钮 */
.page-light .new-session-btn {
  background: rgba(102, 126, 234, 0.1);
  border-color: rgba(102, 126, 234, 0.3);
}

.page-light .new-session-btn text {
  color: #667eea;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-box {
  flex: 1;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  padding: 22rpx 30rpx;
  font-size: 30rpx;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.input-placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.send-btn {
  padding: 22rpx 40rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.4);
  font-size: 30rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #ffd700 0%, #daa520 100%);
  color: #1a1a2e;
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.3);
}

/* ==================== */
/* 日间主题 (Light Mode) */
/* ==================== */
.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.page-light .nav-bar {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.page-light .nav-title text {
  color: #667eea;
}

.page-light .back-btn {
  color: #667eea;
}

.page-light .welcome-bubble {
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.page-light .welcome-greeting,
.page-light .bubble.assistant rich-text {
  color: #333333;
}

.page-light .welcome-text {
  color: #666666;
}

.page-light .bubble.assistant {
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.page-light .bubble.user {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.page-light .input-area {
  background: #ffffff;
  border-top: 1rpx solid #e0e0e0;
}

.page-light .input-box {
  background: #f5f5f5;
  border-color: #e0e0e0;
  color: #333333;
}

.page-light .input-placeholder {
  color: #999999;
}

.page-light .message-time {
  color: rgba(0, 0, 0, 0.3);
}

.page-light .loading-bubble {
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
