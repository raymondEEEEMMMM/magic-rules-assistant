/* pages/agent/agent.wxss */
page {
  background-color: #f5f5f5;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 消息列表 */
.message-list {
  flex: 1;
  height: 0;  /* 关键：让flex生效 */
  padding: 30rpx;
  padding-bottom: 20rpx;
  box-sizing: border-box;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 36rpx;
  text-align: center;
  line-height: 80rpx;
}

.bot-avatar {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  font-size: 44rpx;
}

.bubble {
  max-width: 70%;
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  margin: 0 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-wrap: break-word;
}

.bubble.user {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.bubble.assistant {
  background: #ffffff;
  color: #333;
  border: 1rpx solid #e0e0e0;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 欢迎消息 */
.welcome-message .bubble {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

/* Loading */
.loading-bubble {
  min-width: 100rpx;
  background: #ffffff;
  border: 1rpx solid #e0e0e0;
}

.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #11998e;
  animation: bounce 1.4s infinite ease-in-out both;
}
.loading-bubble {
  min-width: 100rpx;
}

.loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 输入区域 */
.input-area {
  flex-shrink: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 30rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

.input-placeholder {
  color: #999;
}

.send-btn {
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  background: #f0f0f0;
  color: #999;
  font-size: 30rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(56, 239, 125, 0.4);
}
