<!--pages/agent/agent.wxml-->
<view class="container {{isLightTheme ? 'page-light' : ''}}">
  <!-- 加载遮罩 -->
  <view class="loading-overlay" wx:if="{{isLoading}}">
    <view class="loading-content">
      <view class="loading-icon">⚖️</view>
      <view class="loading-text-main">{{loadingText}}</view>
      <view class="loading-progress">
        <view class="progress-dot {{loadingStep >= 1 ? 'active' : ''}}"></view>
        <view class="progress-dot {{loadingStep >= 2 ? 'active' : ''}}"></view>
        <view class="progress-dot {{loadingStep >= 3 ? 'active' : ''}}"></view>
        <view class="progress-dot {{loadingStep >= 4 ? 'active' : ''}}"></view>
      </view>
    </view>
  </view>

  <!-- 顶部导航栏 -->
  <view class="nav-bar {{isLightTheme ? 'nav-bar-light' : ''}}">
    <view class="nav-left">
      <view class="back-btn" bindtap="goBack">←</view>
    </view>
    <view class="nav-title">
      <view class="ai-badge">⚖️</view>
      <text>AI 裁判</text>
    </view>
    <view class="nav-right">
      <view class="theme-toggle" bindtap="toggleTheme">{{isLightTheme ? '🌙' : '☀️'}}</view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y="true" scroll-into-view="{{scrollIntoView}}">
    <!-- 刷新按钮 -->
    <view class="floating-btn-group" bindtap="refreshMessages">
      <text>↻</text>
    </view>
    <!-- 新建会话按钮 -->
    <view class="floating-new-session" bindtap="newSession">
      <text>+ 新建</text>
    </view>
    <!-- 欢迎消息 -->
    <view class="welcome-wrapper" wx:if="{{messages.length === 0}}">
      <view class="welcome-ai">
        <view class="welcome-avatar">⚖️</view>
        <view class="welcome-bubble">
          <text class="welcome-greeting">你好！我是裁判 Agent</text>
          <text class="welcome-text">可以问我任何万智牌规则问题，比如：</text>
          <view class="welcome-examples">
            <view class="example-item" bindtap="useExample" data-q="场上有多个反对派密探时如何互动？">
              ⚡ 反对派密探问题
            </view>
            <view class="example-item" bindtap="useExample" data-q="静止式异能、触发式异能和启动式异能的区别？">
              ⏱️ 不同类型异能间的区别
            </view>
            <view class="example-item" bindtap="useExample" data-q="行旅（companion）在指挥官赛制中如何运作？">
              👥 多人游戏中的行旅规则
            </view>
            <view class="example-item" bindtap="useExample" data-q="帮我查下Doomsday的效果？">
              ✨ 帮我查下Doomsday的效果？
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <view class="message {{item.role}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <view class="message-main">
        <view wx:if="{{item.role === 'assistant'}}" class="avatar bot-avatar">⚖️</view>
        <view class="bubble {{item.role}}">
          <text wx:if="{{item.role === 'user'}}">{{item.content}}</text>
          <rich-text wx:else nodes="{{item.parsedNodes}}"></rich-text>
        </view>
        <view wx:if="{{item.role === 'user'}}" class="avatar user-avatar">👤</view>
      </view>
      <!-- 再问一次按钮（仅最新AI回复显示） -->
      <view class="retry-btn-wrapper" wx:if="{{item.role === 'assistant' && index === messages.length - 1}}">
        <view class="retry-btn" bindtap="retryLast">↻ 再问一次</view>
      </view>
      <view class="message-time" wx:if="{{item.time}}">{{item.time}}</view>
    </view>

    <!-- Loading -->
    <view class="message bot" wx:if="{{loading}}">
      <view class="message-main">
        <view class="avatar bot-avatar">⚖️</view>
        <view class="bubble loading-bubble">
          <text class="loading-text">{{thinkingText || '思考中'}}</text>
          <view class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 等待提示 -->
    <view class="waiting-area" wx:if="{{loading && !thinkingText}}">
      <view class="waiting-tip">异步处理中，请稍后刷新会话试试</view>
    </view>

    <!-- AI 内容免责声明 -->
    <view class="ai-disclaimer">
      <text>⚠️ 内容由 AI 生成，仅供参考</text>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-wrapper">
      <input
        class="input-box"
        type="text"
        placeholder="输入万智牌规则问题..."
        placeholder-class="input-placeholder"
        bindinput="onInput"
        bindconfirm="sendMessage"
        value="{{inputValue}}"
        confirm-type="send"
        maxlength="500"
      />
      <view class="send-btn {{inputValue && !loading ? 'active' : ''}}" bindtap="sendMessage">
        <text>发送</text>
      </view>
    </view>
  </view>
</view>
