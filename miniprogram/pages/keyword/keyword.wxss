/* pages/keyword/keyword.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  padding: 0;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 215, 0, 0.15);
  font-size: 32rpx;
  color: #ffd700;
}

.nav-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 日间主题导航栏 */
.nav-bar.nav-bar-light {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-bar.nav-bar-light .back-btn {
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
}

.nav-bar.nav-bar-light .nav-title {
  color: #667eea;
}

/* 搜索区域 */
.search-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 60rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

.search-clear {
  padding: 8rpx 16rpx;
  color: #999;
  font-size: 28rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: white;
  color: #667eea;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 热门关键词提示 */
.search-tips {
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 20rpx;
}

.tips-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tip-item {
  padding: 16rpx 28rpx;
  background: rgba(102, 126, 234, 0.2);
  border: 1rpx solid rgba(102, 126, 234, 0.3);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #fff;
}

.tip-item:active {
  background: rgba(102, 126, 234, 0.4);
  transform: scale(0.95);
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.3);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 搜索结果 */
.resultsSection {
  padding: 20rpx 30rpx;
}

.results-header {
  margin-bottom: 20rpx;
}

.results-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.result-group {
  margin-bottom: 30rpx;
}

.group-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

/* 关键词列表 */
.keyword-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.keyword-item {
  display: flex;
  align-items: center;
  background: rgba(31, 43, 77, 0.6);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.keyword-item:active {
  background: rgba(102, 126, 234, 0.2);
  transform: scale(0.98);
}

.keyword-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.keyword-info {
  flex: 1;
}

.keyword-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.keyword-brief {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.keyword-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 规则列表 */
.rule-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-item {
  display: flex;
  background: rgba(31, 43, 77, 0.4);
  border-radius: 12rpx;
  padding: 16rpx;
}

.rule-number {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  min-width: 80rpx;
}

.rule-content {
  flex: 1;
}

.rule-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.no-results-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.no-results-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
}

.no-results-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 16rpx;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.detail-content {
  width: 100%;
  max-height: 85vh;
  background: #1a1a2e;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.detail-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  color: white;
  font-size: 32rpx;
}

.detail-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.detailSection {
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 12rpx;
}

.section-content {
  background: rgba(22, 33, 62, 0.8);
  border-radius: 16rpx;
  padding: 24rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.8;
}

.rule-full {
  background: rgba(102, 126, 234, 0.15);
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

.related-rules {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.related-rule {
  display: flex;
  background: rgba(22, 33, 62, 0.6);
  border-radius: 12rpx;
  padding: 16rpx;
}

.related-rule-number {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  min-width: 100rpx;
}

.related-rule-content {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}
