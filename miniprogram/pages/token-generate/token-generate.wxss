/* pages/token-generate/token-generate.wxss */
page { background: var(--bg-page); }
.container { min-height: 100vh; padding: 24rpx 32rpx; display: flex; flex-direction: column; }
.nav-bar { display: flex; align-items: center; padding: 16rpx 0 32rpx; }
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: var(--text-primary); margin-right: 16rpx; }
.back-btn:active { opacity: 0.5; }
.nav-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }

.empty-card { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
.empty-icon { width: 96rpx; height: 96rpx; min-width: 96rpx; min-height: 96rpx; opacity: 0.5; margin-bottom: 24rpx; background-size: contain; background-position: center; background-repeat: no-repeat; }
.empty-text { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.empty-desc { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

/* Token 预览区 */
.preview-card { background: var(--bg-card); border-radius: 20rpx; box-shadow: var(--shadow-card); padding: 24rpx; margin-bottom: 24rpx; }
.preview-title { font-size: 22rpx; color: var(--text-muted); text-align: center; margin-bottom: 16rpx; }
.token-scroll { width: 100%; }
.token-container { display: flex; align-items: center; justify-content: center; gap: 16rpx; }
.token-container.vertical { flex-direction: column; }
.token-container.horizontal { flex-direction: row; flex-wrap: wrap; }
.token-img-wrapper { display: inline-block; }
.token-img { width: 300rpx; height: 418rpx; border-radius: 12rpx; box-shadow: var(--shadow-card); transition: transform 0.3s ease; }
.token-container.horizontal .token-img { width: 200rpx; height: 280rpx; }

/* 控制面板 */
.control-card { background: var(--bg-card); border-radius: 20rpx; box-shadow: var(--shadow-card); padding: 24rpx; margin-bottom: 24rpx; }
.control-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.control-row + .control-row { border-top: 1rpx solid var(--border-subtle); }
.control-label { font-size: 28rpx; color: var(--text-primary); font-weight: 600; }

/* 数量控制 */
.count-control { display: flex; align-items: center; gap: 24rpx; }
.count-btn { width: 64rpx; height: 64rpx; background: var(--bg-input); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.count-btn:active { opacity: 0.7; }
.count-value { font-size: 36rpx; font-weight: 700; color: var(--accent-dark); min-width: 60rpx; text-align: center; }

/* 横置竖置 */
.rotate-control { display: flex; background: var(--bg-input); border-radius: 30rpx; padding: 4rpx; }
.rotate-btn { padding: 12rpx 32rpx; border-radius: 26rpx; font-size: 26rpx; color: var(--text-secondary); }
.rotate-btn.active { background: var(--accent-dark); color: var(--text-inverse); }

/* 预览按钮 */
.preview-btn { background: var(--accent-dark); color: var(--text-inverse); padding: 28rpx; border-radius: 20rpx; text-align: center; font-size: 30rpx; font-weight: 700; margin-top: auto; margin-bottom: 32rpx; }
.preview-btn:active { opacity: 0.7; }
.icon-bg-card { background-image: url("data:image/svg+xml;base64,"); }
