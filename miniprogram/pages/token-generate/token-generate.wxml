<view class="container">
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">Token 生成器</text>
  </view>

  <!-- 无卡图提示 -->
  <view wx:if="{{!card}}" class="empty-card">
    <view class="empty-icon">🃏</view>
    <text class="empty-text">未选择卡牌</text>
    <text class="empty-desc">请先从 Token 列表选择一张 Token</text>
  </view>

  <block wx:else>
    <!-- Token 展示区 -->
    <view class="preview-card">
      <view class="preview-title">长按图片保存</view>
      <scroll-view class="token-scroll" scroll-x="{{!isVertical}}">
        <view class="token-container {{isVertical ? 'vertical' : 'horizontal'}}">
          <view
            class="token-img-wrapper"
            wx:for="{{tokenCount}}"
            wx:key="index"
            bindtap="toggleCardRotate"
            data-index="{{index}}"
          >
            <image
              class="token-img"
              src="{{card.image_uris.normal || card.image_uris.small}}"
              mode="aspectFit"
              style="transform: rotate({{cardRotations[index] || 0}}deg)"
            />
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 控制面板 -->
    <view class="control-card">
      <view class="control-row">
        <text class="control-label">Token 数量</text>
        <view class="count-control">
          <view class="count-btn" bindtap="minusCount">-</view>
          <text class="count-value">{{tokenCount}}</text>
          <view class="count-btn" bindtap="plusCount">+</view>
        </view>
      </view>

      <view class="control-row">
        <text class="control-label">排列方式</text>
        <view class="rotate-control">
          <view class="rotate-btn {{!isVertical ? 'active' : ''}}" bindtap="toggleRotate">
            <text>横置</text>
          </view>
          <view class="rotate-btn {{isVertical ? 'active' : ''}}" bindtap="toggleRotate">
            <text>竖置</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 预览按钮 -->
    <view class="preview-btn" bindtap="previewToken">
      <text>预览大图</text>
    </view>
  </block>
</view>
