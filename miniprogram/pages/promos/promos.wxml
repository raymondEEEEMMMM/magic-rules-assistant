<!--pages/promos/promos.wxml-->
<view class="container {{isLightTheme ? 'page-light' : ''}}">
  <!-- 顶部导航栏 -->
  <view class="nav-bar {{isLightTheme ? 'nav-bar-light' : ''}}">
    <view class="nav-left">
      <view class="back-btn" bindtap="goToIndex">🏠</view>
    </view>
    <view class="nav-title">
      <text>Promo 卡快讯</text>
    </view>
    <view class="nav-right"></view>
  </view>

  <!-- 年份筛选 -->
  <view class="year-filter" wx:if="{{showYearFilter}}">
    <view class="filter-toggle" bindtap="toggleYearFilter">×</view>
    <picker mode="selector" range="{{years}}" bindchange="onYearChange" value="{{years.indexOf(selectedYear)}}">
      <view class="year-value">{{selectedYear}} 年</view>
    </picker>
  </view>
  <view class="show-filter-btn" wx:if="{{!showYearFilter}}" bindtap="toggleYearFilter">
    <text>筛选年份</text>
  </view>

  <!-- 卡牌列表 -->
  <scroll-view class="cards-scroll" scroll-y bindscrolltolower="loadMore">
    <view class="cards-list">
      <view class="promo-item" wx:for="{{cards}}" wx:key="index" bindtap="viewCardDetail" data-card="{{item}}">
        <image class="promo-item-image" src="{{item.image_url}}" mode="aspectFill" />
        <view class="promo-item-info">
          <text class="promo-item-name">{{item.name}}</text>
          <text class="promo-item-set">{{item.set_name}} · {{item.acquisition_method_cn || item.acquisition_method}}</text>
          <text class="promo-item-date">{{item.released_at}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:else bindtap="loadMore">加载更多</text>
    </view>

    <!-- 无数据 -->
    <view class="empty-state" wx:if="{{cards.length === 0 && !loading}}">
      <text class="empty-icon">🎴</text>
      <text class="empty-text">暂无 Promo 卡数据</text>
    </view>
  </scroll-view>
</view>
