/* pages/odds/odds.wxss */
page {
  background: var(--bg-page);
  height: 100%;
  color: var(--text-primary);
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-subtle);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.back-btn:active { opacity: 0.5; }

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
}

.section {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 套牌信息 */
.deck-info-card {
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.deck-info-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.deck-name { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }
.deck-format { font-size: 24rpx; color: var(--color-blue); }
.deck-meta-text { font-size: 24rpx; color: var(--text-secondary); }
.deck-commander-text { font-size: 24rpx; color: var(--accent-gold); margin-top: 4rpx; }

.pick-deck-btn {
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-blue);
  margin-bottom: 16rpx;
}

.pick-deck-btn:active { opacity: 0.7; }

.input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.input-row:last-child { border-bottom: none; }

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.picker-value,
.number-input,
.text-input {
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: right;
  min-width: 200rpx;
}

/* 概率结果 */
.odds-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.odds-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.odds-bar-wrapper {
  height: 24rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
  overflow: hidden;
}

.odds-bar {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.3s;
}

.odds-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
}

.odds-count { color: var(--text-secondary); }
.odds-pct { color: var(--text-primary); font-weight: 700; }

.cumulative-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.cumulative-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.cumulative-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
}

.cumulative-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.cumulative-pct {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-green);
  margin-top: 4rpx;
}

.cumulative-pct.high { color: var(--accent-gold); }

/* 各回合 */
.turns-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.turn-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.turn-num {
  font-size: 24rpx;
  color: var(--color-blue);
  min-width: 50rpx;
  font-weight: 600;
}

.turn-bar-wrapper {
  flex: 1;
  height: 16rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  overflow: hidden;
}

.turn-bar {
  height: 100%;
  background: var(--color-blue);
  border-radius: 8rpx;
}

.turn-pct {
  font-size: 22rpx;
  color: var(--text-primary);
  min-width: 60rpx;
  text-align: right;
  font-weight: 600;
}
