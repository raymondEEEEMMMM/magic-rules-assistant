<!--pages/apitest/apitest.wxml-->
<view class="container {{isLightTheme ? '' : 'theme-dark'}}">
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">API 连通性测试</text>
  </view>

  <!-- 测试列表 -->
  <view class="test-list">
    <!-- AI 裁判测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">AI 裁判 API</text>
        <view class="test-status {{aiJudgeStatus}}">{{aiJudgeStatusText}}</view>
      </view>
      <view class="test-desc">测试与AI裁判服务的连接</view>
      <view class="test-btn {{aiJudgeLoading ? 'disabled' : ''}}" bindtap="testAiJudge">
        {{aiJudgeLoading ? '测试中...' : '开始测试'}}
      </view>
      <view class="test-result" wx:if="{{aiJudgeResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <view class="copy-btn" bindtap="copyResult" data-result="{{aiJudgeResult}}">复制</view>
        </view>
        <text class="result-content" user-select="true">{{aiJudgeResult}}</text>
      </view>
    </view>

    <!-- 规则搜索测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">规则搜索 API</text>
        <view class="test-status {{ruleSearchStatus}}">{{ruleSearchStatusText}}</view>
      </view>
      <view class="test-desc">测试规则搜索功能（关键词：战斗）</view>
      <view class="test-btn {{ruleSearchLoading ? 'disabled' : ''}}" bindtap="testRuleSearch">
        {{ruleSearchLoading ? '测试中...' : '开始测试'}}
      </view>
      <view class="test-result" wx:if="{{ruleSearchResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <view class="copy-btn" bindtap="copyResult" data-result="{{ruleSearchResult}}">复制</view>
        </view>
        <text class="result-content" user-select="true">{{ruleSearchResult}}</text>
      </view>
    </view>

    <!-- 卡牌查询测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">卡牌查询 API</text>
        <view class="test-status {{cardSearchStatus}}">{{cardSearchStatusText}}</view>
      </view>
      <view class="test-desc">测试卡牌查询功能（卡牌：黑莲花）</view>
      <view class="test-btn {{cardSearchLoading ? 'disabled' : ''}}" bindtap="testCardSearch">
        {{cardSearchLoading ? '测试中...' : '开始测试'}}
      </view>
      <view class="test-result" wx:if="{{cardSearchResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <view class="copy-btn" bindtap="copyResult" data-result="{{cardSearchResult}}">复制</view>
        </view>
        <text class="result-content" user-select="true">{{cardSearchResult}}</text>
      </view>
    </view>

    <!-- 关键词查询测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">关键词查询 API</text>
        <view class="test-status {{keywordStatus}}">{{keywordStatusText}}</view>
      </view>
      <view class="test-desc">测试关键词查询功能（关键词：飞行）</view>
      <view class="test-btn {{keywordLoading ? 'disabled' : ''}}" bindtap="testKeyword">
        {{keywordLoading ? '测试中...' : '开始测试'}}
      </view>
      <view class="test-result" wx:if="{{keywordResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <view class="copy-btn" bindtap="copyResult" data-result="{{keywordResult}}">复制</view>
        </view>
        <text class="result-content" user-select="true">{{keywordResult}}</text>
      </view>
    </view>
  </view>
</view>
