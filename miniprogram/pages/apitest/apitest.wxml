<!--pages/apitest/apitest.wxml-->
<view class="container">
  <view class="header">
    <text class="title">API 连通性测试</text>
  </view>

  <!-- 测试列表 -->
  <view class="test-list">
    <!-- AI 裁判测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">AI 裁判 API</text>
        <view class="test-status {{aiJudgeStatus}}">{{aiJudgeStatusText}}</view>
      </view>
      <view class="test-desc">测试与AI裁判服务的连接</view>
      <button class="test-btn" bindtap="testAiJudge" loading="{{aiJudgeLoading}}">
        {{aiJudgeLoading ? '测试中...' : '开始测试'}}
      </button>
      <view class="test-result" wx:if="{{aiJudgeResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <button class="copy-btn" bindtap="copyResult" data-result="{{aiJudgeResult}}">复制</button>
        </view>
        <text class="result-content">{{aiJudgeResult}}</text>
      </view>
    </view>

    <!-- 规则搜索测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">规则搜索 API</text>
        <view class="test-status {{ruleSearchStatus}}">{{ruleSearchStatusText}}</view>
      </view>
      <view class="test-desc">测试规则搜索功能（关键词：战斗）</view>
      <button class="test-btn" bindtap="testRuleSearch" loading="{{ruleSearchLoading}}">
        {{ruleSearchLoading ? '测试中...' : '开始测试'}}
      </button>
      <view class="test-result" wx:if="{{ruleSearchResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <button class="copy-btn" bindtap="copyResult" data-result="{{ruleSearchResult}}">复制</button>
        </view>
        <text class="result-content">{{ruleSearchResult}}</text>
      </view>
    </view>

    <!-- 卡牌查询测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">卡牌查询 API</text>
        <view class="test-status {{cardSearchStatus}}">{{cardSearchStatusText}}</view>
      </view>
      <view class="test-desc">测试卡牌查询功能（卡牌：黑莲花）</view>
      <button class="test-btn" bindtap="testCardSearch" loading="{{cardSearchLoading}}">
        {{cardSearchLoading ? '测试中...' : '开始测试'}}
      </button>
      <view class="test-result" wx:if="{{cardSearchResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <button class="copy-btn" bindtap="copyResult" data-result="{{cardSearchResult}}">复制</button>
        </view>
        <text class="result-content">{{cardSearchResult}}</text>
      </view>
    </view>

    <!-- 关键词查询测试 -->
    <view class="test-item">
      <view class="test-header">
        <text class="test-name">关键词查询 API</text>
        <view class="test-status {{keywordStatus}}">{{keywordStatusText}}</view>
      </view>
      <view class="test-desc">测试关键词查询功能（关键词：飞行）</view>
      <button class="test-btn" bindtap="testKeyword" loading="{{keywordLoading}}">
        {{keywordLoading ? '测试中...' : '开始测试'}}
      </button>
      <view class="test-result" wx:if="{{keywordResult}}">
        <view class="result-header">
          <text class="result-label">返回结果：</text>
          <button class="copy-btn" bindtap="copyResult" data-result="{{keywordResult}}">复制</button>
        </view>
        <text class="result-content">{{keywordResult}}</text>
      </view>
    </view>
  </view>
</view>
