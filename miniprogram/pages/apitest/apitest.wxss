/* pages/apitest/apitest.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  padding: 30rpx;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.test-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.test-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.test-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.test-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.test-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.test-status.pending {
  background: #f0f0f0;
  color: #999;
}

.test-status.success {
  background: #e8f5e9;
  color: #4caf50;
}

.test-status.error {
  background: #ffebee;
  color: #f44336;
}

.test-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.test-btn {
  background: #1a1a2e;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.test-result {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.result-label {
  font-size: 26rpx;
  color: #666;
}

.copy-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  background: #1a1a2e;
  color: #fff;
  border-radius: 6rpx;
  line-height: 1.5;
  min-height: auto;
}

.result-content {
  font-size: 24rpx;
  color: #333;
  display: block;
  word-break: break-all;
  white-space: pre-wrap;
}
