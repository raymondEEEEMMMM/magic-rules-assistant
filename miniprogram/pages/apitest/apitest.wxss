/* pages/apitest/apitest.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eee;
}

.api-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.test-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.test-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  background-color: #f0f0f0;
  color: #333;
  transition: all 0.3s;
}

.test-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.test-btn.danger {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.test-btn:not([disabled]):active {
  transform: scale(0.98);
  opacity: 0.8;
}

.test-btn[disabled] {
  opacity: 0.5;
}

.result-summary {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.summary-value.success {
  color: #52c41a;
}

.summary-value.error {
  color: #f5222d;
}

.results-section {
  max-height: 800rpx;
  overflow-y: auto;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  background-color: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
  border-left: 6rpx solid #d9d9d9;
}

.result-item.success {
  border-left-color: #52c41a;
  background-color: #f6ffed;
}

.result-item.fail {
  border-left-color: #f5222d;
  background-color: #fff2f0;
}

.result-header {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: white;
}

.result-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.result-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.result-time {
  font-size: 24rpx;
  color: #999;
}

.result-content {
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #eee;
}

.result-path {
  font-size: 24rpx;
  color: #1890ff;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.result-code {
  font-size: 24rpx;
  color: #52c41a;
  margin-bottom: 8rpx;
}

.result-data {
  margin-bottom: 12rpx;
}

.result-data-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.result-data-value {
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
  max-height: 200rpx;
  overflow-y: auto;
}

.result-error {
  padding-top: 12rpx;
  border-top: 1rpx dashed #ff4d4f;
}

.result-error-label {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-right: 8rpx;
}

.result-error-value {
  font-size: 24rpx;
  color: #ff4d4f;
  word-break: break-all;
}

.clear-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #fff0f6;
  color: #c41d7f;
  border: 2rpx solid #ffadd2;
}
