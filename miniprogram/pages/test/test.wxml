<!--pages/test/test.wxml-->
<view class="container">
  <view class="header">
    <text class="title">🧪 关键词模块测试</text>
    <text class="subtitle">快速测试关键词模块的各项功能</text>
  </view>

  <!-- 测试项目列表 -->
  <view class="test-section">
    <view class="section-title">📋 测试项目</view>
    <view class="test-list">
      <view 
        class="test-item {{item.status}}" 
        wx:for="{{testItems}}" 
        wx:key="id"
        bindtap="runTest"
        data-test="{{item}}"
      >
        <view class="test-item-header">
          <text class="test-icon">{{item.status === 'success' ? '✅' : item.status === 'fail' ? '❌' : item.status === 'running' ? '⏳' : '⭕'}}</text>
          <text class="test-name">{{item.name}}</text>
          <text class="test-time" wx:if="{{item.time}}">{{item.time}}ms</text>
        </view>
        <view class="test-desc">{{item.description}}</view>
        <view class="test-error" wx:if="{{item.error}}">
          <text class="error-label">错误:</text>
          <text class="error-text">{{item.error}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 测试控制 -->
  <view class="control-section">
    <view class="section-title">🎮 测试控制</view>
    <view class="control-buttons">
      <button class="control-btn primary" bindtap="runAllTests" disabled="{{isTesting}}">
        {{isTesting ? '测试中...' : '🚀 运行全部测试'}}
      </button>
      <button class="control-btn" bindtap="resetTests" disabled="{{isTesting}}">
        🔄 重置测试
      </button>
      <button class="control-btn" bindtap="goToKeyword" disabled="{{isTesting}}">
        📖 前往关键词页面
      </button>
    </view>
  </view>

  <!-- 测试摘要 -->
  <view class="summary-section" wx:if="{{testCount > 0}}">
    <view class="section-title">📊 测试摘要</view>
    <view class="summary-grid">
      <view class="summary-item">
        <text class="summary-value total">{{testCount}}</text>
        <text class="summary-label">总测试数</text>
      </view>
      <view class="summary-item">
        <text class="summary-value success">{{successCount}}</text>
        <text class="summary-label">成功</text>
      </view>
      <view class="summary-item">
        <text class="summary-value fail">{{failCount}}</text>
        <text class="summary-label">失败</text>
      </view>
      <view class="summary-item">
        <text class="summary-value time">{{totalTime}}ms</text>
        <text class="summary-label">总耗时</text>
      </view>
    </view>
  </view>

  <!-- 快速测试入口 -->
  <view class="quick-test-section">
    <view class="section-title">⚡ 快速测试</view>
    <view class="quick-test-buttons">
      <button class="quick-btn" bindtap="testLocalSearch" disabled="{{isTesting}}">
        📱 本地搜索测试
      </button>
      <button class="quick-btn" bindtap="testApiSearch" disabled="{{isTesting}}">
        🌐 API搜索测试
      </button>
      <button class="quick-btn" bindtap="testAutoTest" disabled="{{isTesting}}">
        🤖 自动化测试
      </button>
    </view>
  </view>
</view>
