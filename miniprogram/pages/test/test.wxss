/* pages/test/test.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* Header */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* Section */
.test-section, .control-section, .summary-section, .quick-test-section {
  background: rgba(31, 43, 77, 0.6);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e94560;
}

/* Test List */
.test-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.test-item {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 6rpx solid #d9d9d9;
  transition: all 0.3s ease;
}

.test-item:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.05);
}

.test-item.success {
  border-left-color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
}

.test-item.fail {
  border-left-color: #f5222d;
  background: rgba(245, 34, 45, 0.1);
}

.test-item.running {
  border-left-color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
}

.test-item-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.test-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.test-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}

.test-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.test-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.test-error {
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(255, 255, 255, 0.2);
}

.error-label {
  font-size: 22rpx;
  color: #f5222d;
  margin-right: 8rpx;
}

.error-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* Control Buttons */
.control-buttons, .quick-test-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.control-btn, .quick-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  transition: all 0.3s ease;
}

.control-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.control-btn:not([disabled]):active, .quick-btn:not([disabled]):active {
  transform: scale(0.98);
  opacity: 0.8;
}

.control-btn[disabled], .quick-btn[disabled] {
  opacity: 0.5;
}

/* Summary Grid */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.summary-item {
  text-align: center;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
}

.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.summary-value.total {
  color: #1890ff;
}

.summary-value.success {
  color: #52c41a;
}

.summary-value.fail {
  color: #f5222d;
}

.summary-value.time {
  color: #ffd700;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}
