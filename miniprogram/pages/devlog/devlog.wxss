/* pages/devlog/devlog.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
  height: 100%;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

.nav-bar-light {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-bar-light .back-btn,
.nav-bar-light .nav-title text {
  color: #333333;
}

/* 版本列表 */
.version-list {
  flex: 1;
  padding: 20rpx;
}

/* 版本项 */
.version-item {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.version-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.version-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
}

.version-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 更新项 */
.version-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.log-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.log-tag-feat {
  background: rgba(82, 196, 26, 0.2);
  color: #52c41a;
}

.log-tag-fix {
  background: rgba(255, 77, 79, 0.2);
  color: #ff4d4f;
}

.log-tag-perf {
  background: rgba(24, 144, 255, 0.2);
  color: #1890ff;
}

.log-content {
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.5;
  flex: 1;
}

/* ==================== */
/* 日间主题 (Light Mode) */
/* ==================== */
.container.page-light {
  background-color: #f5f5f5;
}

.page-light .nav-bar {
  background: #ffffff;
  border-bottom-color: #e0e0e0;
}

.page-light .nav-title text {
  color: #333333;
}

.page-light .back-btn {
  color: #667eea;
}

.page-light .version-list {
  background: #f5f5f5;
}

.page-light .version-item {
  background: #ffffff;
  border-color: rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.page-light .version-header {
  border-bottom-color: rgba(102, 126, 234, 0.2);
}

.page-light .version-number {
  color: #667eea;
}

.page-light .version-date {
  color: #999;
}

.page-light .log-content {
  color: #333;
}

.page-light .log-tag-feat {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.page-light .log-tag-fix {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.page-light .log-tag-perf {
  background: rgba(24, 144, 255, 0.15);
  color: #1890ff;
}