/* pages/sldcards/sldcards.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  padding: 0;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(155, 89, 182, 0.3);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #9b59b6;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.view-toggle {
  font-size: 40rpx;
}

/* 搜索栏 */
.search-section {
  padding: 20rpx 30rpx;
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(155, 89, 182, 0.2);
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.search-btn {
  font-size: 28rpx;
  color: #9b59b6;
  font-weight: bold;
}

.search-tip {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(155, 89, 182, 0.2);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.search-result-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-result-image {
  width: 80rpx;
  height: 112rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.1);
}

.search-result-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.search-result-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.search-result-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.search-clear-btn {
  font-size: 26rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
}

.search-no-result {
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  background: rgba(233, 69, 96, 0.2);
  border-radius: 8rpx;
  display: inline-block;
}

.search-no-result text {
  font-size: 24rpx;
  color: #e94560;
}

/* 日期分组 */
.date-groups {
  padding: 20rpx;
}

.date-group {
  margin-bottom: 30rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.3) 0%, rgba(155, 89, 182, 0.15) 100%);
  border-radius: 12rpx;
  border-left: 6rpx solid #9b59b6;
  margin-bottom: 16rpx;
}

.date-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.date-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.toggle-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 卡牌网格视图 - 3列 */
.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  padding: 10rpx;
}

.card-grid-item {
  position: relative;
  width: 100%;
  aspect-ratio: 5/7;
  background: #1a1a2e;
  border-radius: 6rpx;
  overflow: hidden;
}

.card-grid-image {
  width: 100%;
  height: 100%;
}

.card-grid-name {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  font-size: 16rpx;
  color: #fff;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  padding: 20rpx 4rpx 4rpx;
  text-align: center;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-grid-code {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  font-size: 16rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.6);
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
}

/* 卡牌列表视图 */
.card-list {
  padding: 10rpx;
}

.card-list-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
}

.card-list-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.card-list-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.card-list-code {
  font-size: 22rpx;
  color: #9b59b6;
  background: rgba(155, 89, 182, 0.2);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.card-list-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-results-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #9b59b6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== */
/* 日间主题 (Light Mode) */
/* ==================== */
.container.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.container.page-light .nav-bar {
  background: #ffffff;
  border-bottom-color: #e0e0e0;
}

.container.page-light .back-btn {
  color: #9b59b6;
}

.container.page-light .nav-title {
  color: #333333;
}

.container.page-light .search-section {
  background: #ffffff;
  border-bottom-color: #e0e0e0;
}

.container.page-light .search-box {
  background: rgba(0, 0, 0, 0.05);
}

.container.page-light .search-input {
  color: #333333;
}

.container.page-light .search-placeholder {
  color: rgba(0, 0, 0, 0.5);
}

.container.page-light .search-btn {
  color: #9b59b6;
}

.container.page-light .search-tip {
  background: rgba(155, 89, 182, 0.15);
}

.container.page-light .search-result-name {
  color: #333333;
}

.container.page-light .search-result-meta {
  color: rgba(0, 0, 0, 0.6);
}

.container.page-light .search-clear-btn {
  color: #667eea;
}

.container.page-light .search-no-result {
  background: rgba(233, 69, 96, 0.1);
}

.container.page-light .search-no-result text {
  color: #e94560;
}

.container.page-light .date-header {
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.15) 0%, rgba(155, 89, 182, 0.08) 100%);
  border-left-color: #9b59b6;
}

.container.page-light .date-label {
  color: #333333;
}

.container.page-light .date-count {
  color: rgba(0, 0, 0, 0.6);
  background: rgba(0, 0, 0, 0.05);
}

.container.page-light .card-grid-item {
  background: rgba(255, 255, 255, 0.95);
}

.container.page-light .card-grid-name {
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
}

.container.page-light .card-list-item {
  background: rgba(255, 255, 255, 0.95);
}

.container.page-light .card-list-name {
  color: #333333;
}

.container.page-light .card-list-code {
  color: #9b59b6;
  background: rgba(155, 89, 182, 0.15);
}

.container.page-light .card-list-type {
  color: rgba(0, 0, 0, 0.6);
}

.container.page-light .no-results-text {
  color: #666666;
}

.container.page-light .loading-spinner {
  border-color: rgba(155, 89, 182, 0.2);
  border-top-color: #9b59b6;
}
