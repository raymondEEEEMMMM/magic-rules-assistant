<!-- API 使用示例页面 -->
<view class="container">
  <view class="header">
    <text class="title">API 使用示例</text>
    <text class="subtitle">mtgAsk API 使用示例</text>
  </view>

  <!-- 输入框 -->
  <view class="input-section">
    <view class="input-wrapper">
      <input
        class="input"
        placeholder="请输入关键词或卡牌名称"
        value="{{keyword}}"
        bindinput="onInput"
        placeholder-class="input-placeholder"
      />
    </view>

    <!-- 按钮组 -->
    <view class="button-group">
      <button
        class="btn btn-primary"
        bindtap="handleSearchRules"
        loading="{{loading}}"
      >
        搜索规则
      </button>
      <button
        class="btn btn-secondary"
        bindtap="handleGetKeyword"
        loading="{{loading}}"
      >
        查询关键词
      </button>
      <button
        class="btn btn-accent"
        bindtap="handleSearchCard"
        loading="{{loading}}"
      >
        搜索卡牌
      </button>
    </view>

    <!-- 操作按钮 -->
    <view class="action-group">
      <button class="btn btn-outline" bindtap="handleClear">清空结果</button>
      <button class="btn btn-outline" bindtap="handleTestStatus">测试服务</button>
    </view>
  </view>

  <!-- 规则搜索结果 -->
  <view wx:if="{{results.length > 0}}" class="result-section">
    <view class="result-header">
      <text class="result-title">规则搜索结果 ({{results.length}}条)</text>
    </view>
    <view class="result-list">
      <view class="result-item" wx:for="{{results}}" wx:key="rule_number">
        <view class="rule-number">{{item.rule_number}}</view>
        <view class="rule-content">{{item.rule_content}}</view>
      </view>
    </view>
  </view>

  <!-- 卡牌搜索结果 -->
  <view wx:if="{{cardResult && cardResult.length > 0}}" class="result-section">
    <view class="result-header">
      <text class="result-title">卡牌搜索结果 ({{cardResult.length}}张)</text>
    </view>
    <view class="result-list">
      <view class="result-item" wx:for="{{cardResult}}" wx:key="id">
        <view class="card-name">{{item.name}}</view>
        <view class="card-type">{{item.type}}</view>
        <view class="card-text" wx:if="{{item.oracle_text}}">
          {{item.oracle_text}}
        </view>
      </view>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="tips-section">
    <view class="tips-title">💡 使用提示</view>
    <view class="tips-content">
      <text class="tip-item">• 搜索规则：输入"combat"、"instant"等关键词</text>
      <text class="tip-item">• 查询关键词：输入"Flying"、"飞行"等</text>
      <text class="tip-item">• 搜索卡牌：输入卡牌名称，如"Lightning Bolt"</text>
    </view>
  </view>
</view>
