/* API 使用示例页面样式 */
.container {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  background: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* 输入区域 */
.input-section {
  margin-bottom: 40rpx;
}

.input-wrapper {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.input {
  width: 100%;
  font-size: 32rpx;
  color: #333;
}

.input-placeholder {
  color: #ccc;
}

/* 按钮组 */
.button-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: none;
  padding: 0 32rpx;
  transition: all 0.3s;
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-secondary {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.btn-accent {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.action-group {
  display: flex;
  gap: 24rpx;
}

.action-group .btn {
  flex: 1;
}

/* 结果区域 */
.result-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-item {
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.rule-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 12rpx;
}

.rule-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.card-type {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.card-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 提示区域 */
.tips-section {
  background: #fff8e1;
  border-radius: 16rpx;
  padding: 32rpx;
  border-left: 8rpx solid #ffc107;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f57c00;
  margin-bottom: 16rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #e65100;
  line-height: 1.6;
}
