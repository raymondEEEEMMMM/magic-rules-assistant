/* pages/loading/loading.wxss */
page { background: var(--bg-page); }

.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.loading-icon {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 64rpx;
}

.pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid var(--accent-dark);
  animation: pulse 2s ease-out infinite;
  opacity: 0.5;
}

.pulse-ring.delay-1 { animation-delay: 0.5s; }
.pulse-ring.delay-2 { animation-delay: 1s; }

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.loading-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  min-height: 100rpx;
  transition: all 0.3s ease;
}

.loading-progress {
  width: 100%;
  height: 6rpx;
  background: var(--bg-input);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--accent-dark);
  border-radius: 3rpx;
  transition: width 0.5s ease;
}
