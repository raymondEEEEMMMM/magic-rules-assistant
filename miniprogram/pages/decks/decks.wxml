<view class="container">
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">我的套牌</text>
    <view class="nav-action" bindtap="showImport">+</view>
  </view>

  <!-- 套牌列表 -->
  <view wx:if="{{decks.length > 0}}" class="deck-list">
    <view
      class="deck-card"
      wx:for="{{decks}}"
      wx:key="_id"
      bindtap="previewDeck"
      data-deck="{{item}}"
    >
      <view class="deck-info">
        <text class="deck-name">{{item.name}}</text>
        <view class="deck-tags">
          <text class="deck-tag format">{{item.format || '其他'}}</text>
          <text wx:if="{{item.commander}}" class="deck-tag commander">⌘ {{item.commander}}</text>
        </view>
        <view class="deck-meta">
          <text class="deck-count">{{item.totalCards || 0}} 张</text>
          <text wx:if="{{item.avgCMC}}" class="deck-cmc">· 平均法术力费用 {{item.avgCMC}}</text>
        </view>
      </view>
      <view class="deck-arrow">›</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{decks.length === 0}}" class="empty">
    <view class="empty-icon">📚</view>
    <text class="empty-title">还没有套牌</text>
    <text class="empty-desc">从 MTGGoldfish / Moxfield 导入或新建</text>
    <view class="empty-btn" bindtap="showImport">新建套牌</view>
  </view>
</view>
