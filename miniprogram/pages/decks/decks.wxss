/* pages/decks/decks.wxss */
page {
  background-color: #16213e;
  height: 100%;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
}

.add-btn {
  font-size: 48rpx;
  color: #667eea;
  font-weight: bold;
}

.nav-bar-light {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-bar-light .back-btn,
.nav-bar-light .nav-title {
  color: #333333;
}

/* 套牌列表 */
.deck-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.deck-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.deck-card:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.deck-info {
  flex: 1;
}

.deck-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.deck-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.deck-format {
  color: #ffffff;
  background: #667eea;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
  writing-mode: vertical-rl;
}

.deck-count,
.deck-cards-count {
  color: rgba(255, 255, 255, 0.6);
}

.deck-cm {
  color: #38ef7d;
}

.deck-commander-tag {
  font-size: 22rpx;
  color: #ffd700;
}

.deck-commander {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.commander-label {
  color: #ffd700;
}

.commander-name {
  color: #ffd700;
}

.deck-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal.show {
  display: flex;
}

.modal-content {
  width: 640rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.modal-close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 10rpx;
}

.modal-large {
  width: 700rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12rpx;
  display: block;
}

.input-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.paste-btn {
  font-size: 26rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
}

/* 指挥官搜索 */
.commander-group {
  position: relative;
}

.commander-search-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.commander-search-btn {
  font-size: 36rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.commander-search-btn:active {
  opacity: 0.7;
}

.commander-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #1a1a2e;
  border-radius: 12rpx;
  margin-top: 8rpx;
  z-index: 100;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  max-height: 500rpx;
  overflow-y: auto;
}

.commander-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.commander-option:last-child {
  border-bottom: none;
}

.commander-option:active {
  background: rgba(255, 255, 255, 0.05);
}

.commander-thumb {
  width: 60rpx;
  height: 84rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.commander-info {
  flex: 1;
  min-width: 0;
}

.commander-info .commander-name {
  font-size: 28rpx;
  color: #ffffff;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.commander-info .commander-type {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.input-field {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #ffffff;
}

.picker-value {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #ffffff;
}

.textarea-field {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #ffffff;
  min-height: 120rpx;
  max-height: 240rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 解析结果 */
.parse-result {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.parse-success {
  font-size: 28rpx;
  color: #38ef7d;
  margin-bottom: 16rpx;
}

.result-cm {
  color: #38ef7d;
}

.result-commander {
  color: #ffd700;
}

.parse-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.preview-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.05);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.preview-more {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 6rpx 16rpx;
}

.parse-errors {
  margin-top: 12rpx;
}

.error-text {
  font-size: 24rpx;
  color: #f5576c;
  display: block;
  margin-top: 6rpx;
}

/* 操作按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
}

.parse-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.export-btn {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #ffffff;
}

.delete-btn {
  background: rgba(245, 87, 108, 0.2);
  color: #f5576c;
}

.detail-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.odds-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

/* 套牌详情 */
.deck-detail-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-tag {
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.deck-cards-scroll {
  max-height: 400rpx;
  margin-bottom: 24rpx;
}

.deck-cards-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.deck-card-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.card-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  min-width: 50rpx;
}

.card-name {
  font-size: 28rpx;
  color: #ffffff;
}

/* 简化 Odds 计算器 */
.odds-calc {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.odds-calc-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 16rpx;
}

.odds-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.odds-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  min-width: 120rpx;
}

.odds-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.odds-input.small {
  width: 120rpx;
  flex: none;
}

.odds-result {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(102, 126, 234, 0.15);
  border-radius: 8rpx;
}

.odds-pct {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

/* Light theme */
.container.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.container.page-light .deck-card {
  background: rgba(0, 0, 0, 0.03);
  border-color: rgba(0, 0, 0, 0.05);
}

.container.page-light .deck-name {
  color: #333333;
}

.container.page-light .deck-arrow {
  color: rgba(0, 0, 0, 0.2);
}

.container.page-light .empty-text {
  color: #666666;
}

.container.page-light .modal-content {
  background: #ffffff;
}

.container.page-light .modal-title {
  color: #333333;
}

.container.page-light .input-field,
.container.page-light .picker-value,
.container.page-light .textarea-field {
  background: rgba(0, 0, 0, 0.05);
  color: #333333;
}

.container.page-light .input-label {
  color: #666666;
}

.container.page-light .deck-cm {
  color: #27ae60;
}

.container.page-light .deck-commander {
  color: #666;
}

.container.page-light .deck-count,
.container.page-light .deck-cards-count {
  color: rgba(0, 0, 0, 0.6);
}

.container.page-light .deck-commander-tag {
  color: #d4a017;
}

.container.page-light .deck-format {
  background: #667eea;
  color: #ffffff;
}

.container.page-light .commander-label,
.container.page-light .commander-name {
  color: #d4a017;
}

.container.page-light .detail-tag {
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
}

.container.page-light .card-name {
  color: #333;
}

.container.page-light .card-count {
  color: #667eea;
}

.container.page-light .deck-card-item {
  border-bottom-color: rgba(0, 0, 0, 0.05);
}

.container.page-light .parse-success {
  color: #27ae60;
}

.container.page-light .result-cm {
  color: #27ae60;
}

.container.page-light .result-commander {
  color: #d4a017;
}

/* Light theme - commander search */
.container.page-light .commander-search-btn {
  background: rgba(0, 0, 0, 0.05);
  color: #999;
}

.container.page-light .commander-dropdown {
  background: #ffffff;
}

.container.page-light .commander-option {
  border-bottom-color: rgba(0, 0, 0, 0.05);
}

.container.page-light .commander-option:active {
  background: rgba(0, 0, 0, 0.03);
}

.container.page-light .commander-info .commander-name {
  color: #333;
}

.container.page-light .commander-info .commander-type {
  color: #999;
}

/* Light theme - odds calc */
.container.page-light .odds-calc {
  background: rgba(0, 0, 0, 0.05);
}

.container.page-light .odds-label {
  color: #666;
}

.container.page-light .odds-input {
  background: rgba(0, 0, 0, 0.05);
  color: #333;
}

.container.page-light .odds-result {
  background: rgba(102, 126, 234, 0.1);
}
