/* pages/decks/decks.wxss */
page { background: var(--bg-page); }
.container { min-height: 100vh; padding: 24rpx 32rpx; }
.nav-bar { display: flex; align-items: center; padding: 16rpx 0 32rpx; }
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: var(--text-primary); margin-right: 16rpx; }
.back-btn:active { opacity: 0.5; }
.nav-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); flex: 1; }
.nav-action { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; font-weight: 300; color: var(--accent-dark); }
.nav-action:active { opacity: 0.5; }

.deck-list { display: flex; flex-direction: column; gap: 16rpx; }
.deck-card { background: var(--bg-card); border-radius: 20rpx; box-shadow: var(--shadow-card); padding: 24rpx; display: flex; align-items: center; gap: 16rpx; }
.deck-card:active { opacity: 0.7; }
.deck-info { flex: 1; min-width: 0; }
.deck-name { font-size: 32rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 12rpx; display: block; }
.deck-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 8rpx; }
.deck-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.deck-tag.format { background: var(--bg-input); color: var(--text-secondary); }
.deck-tag.commander { background: var(--accent-gold); color: var(--accent-dark); }
.deck-meta { font-size: 22rpx; color: var(--text-secondary); }
.deck-count { font-weight: 600; }
.deck-cmc { margin-left: 4rpx; }
.deck-arrow { font-size: 40rpx; color: var(--text-muted); }

.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 96rpx; opacity: 0.5; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.empty-desc { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }
.empty-btn { margin-top: 32rpx; background: var(--accent-dark); color: var(--text-inverse); padding: 20rpx 48rpx; border-radius: 32rpx; font-size: 28rpx; font-weight: 600; }
.empty-btn:active { opacity: 0.7; }

/* Modal 通用 */
.modal { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; display: none; align-items: flex-end; justify-content: center; }
.modal.show { display: flex; }
.modal-content { background: var(--bg-card); border-radius: 32rpx 32rpx 0 0; padding: 32rpx 32rpx 48rpx; width: 100%; max-width: 750rpx; max-height: 85vh; overflow-y: auto; box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.15); }
.modal-content.modal-large { max-height: 90vh; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 24rpx; border-bottom: 1rpx solid var(--border-subtle); margin-bottom: 24rpx; }
.modal-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.modal-close { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: var(--text-muted); }
.modal-close:active { opacity: 0.6; }
.modal-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.action-btn { flex: 1; padding: 24rpx 0; border-radius: 20rpx; font-size: 28rpx; font-weight: 600; text-align: center; background: var(--bg-input); color: var(--text-primary); }
.action-btn:active { opacity: 0.7; }
.action-btn.confirm-btn { background: var(--accent-dark); color: var(--text-inverse); }
.action-btn.delete-btn { background: #d33; color: #fff; }
.action-btn.detail-btn { background: var(--accent-dark); color: var(--text-inverse); }

/* 表单输入 */
.input-group { margin-bottom: 24rpx; }
.input-label { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 12rpx; }
.input-label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.input-field { background: var(--bg-input); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: var(--text-primary); width: 100%; box-sizing: border-box; }
.textarea-field { background: var(--bg-input); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 26rpx; color: var(--text-primary); width: 100%; min-height: 200rpx; box-sizing: border-box; }
.picker-value { background: var(--bg-input); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: var(--text-primary); }
.paste-btn { background: var(--bg-input); color: var(--accent-dark); padding: 8rpx 20rpx; border-radius: 12rpx; font-size: 22rpx; font-weight: 600; }
.paste-btn:active { opacity: 0.7; }
.url-import-btn { background: var(--accent-dark); color: var(--text-inverse); border-radius: 16rpx; padding: 20rpx 0; text-align: center; font-size: 28rpx; font-weight: 600; margin-top: 16rpx; }
.url-import-btn:active { opacity: 0.8; }

/* 指挥官搜索 */
.commander-search-row { display: flex; gap: 12rpx; align-items: center; }
.commander-search-row .input-field { flex: 1; }
.commander-search-btn { width: 80rpx; height: 80rpx; background: var(--accent-dark); color: var(--text-inverse); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.commander-dropdown { background: var(--bg-card); border: 1rpx solid var(--border-subtle); border-radius: 16rpx; margin-top: 12rpx; max-height: 400rpx; overflow-y: auto; }
.commander-option { display: flex; align-items: center; gap: 16rpx; padding: 16rpx; border-bottom: 1rpx solid var(--border-subtle); }
.commander-option:last-child { border-bottom: none; }
.commander-option:active { background: var(--bg-input); }
.commander-thumb { width: 80rpx; height: 112rpx; border-radius: 8rpx; background: var(--bg-input); }
.commander-info { flex: 1; min-width: 0; }
.commander-name { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; }
.commander-type { font-size: 22rpx; color: var(--text-secondary); }

/* 解析结果 */
.parse-result { background: var(--bg-input); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.parse-success { font-size: 26rpx; color: var(--text-primary); margin-bottom: 12rpx; }
.result-cm { color: var(--accent-dark); font-weight: 600; }
.result-commander { color: var(--accent-gold); font-weight: 600; }
.parse-preview { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 12rpx; }
.preview-item { font-size: 24rpx; color: var(--text-secondary); }
.preview-more { font-size: 22rpx; color: var(--text-muted); font-style: italic; }
.parse-errors { border-top: 1rpx solid var(--border-subtle); padding-top: 12rpx; margin-top: 12rpx; }
.error-text { font-size: 22rpx; color: #d33; display: block; }

/* 套牌预览 */
.deck-detail-meta { display: flex; gap: 12rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.detail-tag { background: var(--bg-input); color: var(--text-primary); padding: 8rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.deck-commander { font-size: 26rpx; color: var(--text-primary); margin-bottom: 16rpx; }
.commander-label { color: var(--text-secondary); }
.commander-name { color: var(--accent-gold); font-weight: 600; }
.deck-cards-scroll { max-height: 50vh; }
.deck-cards-list { display: flex; flex-direction: column; gap: 8rpx; }
.deck-card-item { display: flex; gap: 16rpx; padding: 12rpx 16rpx; background: var(--bg-input); border-radius: 12rpx; }
.card-count { font-weight: 700; color: var(--accent-dark); min-width: 48rpx; font-size: 26rpx; }
.card-name { flex: 1; color: var(--text-primary); font-size: 26rpx; }
