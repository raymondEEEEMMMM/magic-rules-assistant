<!--pages/search/search.wxml-->
<view class="container {{isLightTheme ? 'page-light' : ''}}">
  <!-- 导航栏 -->
  <view class="nav-bar {{isLightTheme ? 'nav-bar-light' : ''}}">
    <view class="nav-left">
      <view class="back-btn" bindtap="goBack">←</view>
    </view>
    <view class="nav-title">
      <text>搜索</text>
    </view>
    <view class="nav-right"></view>
  </view>

  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索..."
        placeholder-class="search-placeholder"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
        focus="{{searchFocused}}"
        value="{{keyword}}"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">
        <text>✕</text>
      </view>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!keyword && history.length > 0}}">
    <view class="history-header">
      <text class="history-title">历史记录</text>
      <text class="history-clear" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view
        class="history-item"
        wx:for="{{history}}"
        wx:key="index"
        bindtap="useHistory"
        data-keyword="{{item}}"
      >
        <text class="history-icon">🕐</text>
        <text class="history-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 组合搜索结果 -->
  <view class="combined-results" wx:if="{{keyword && (loading || searchDone || combinedResults.keywords.length > 0 || combinedResults.cards.length > 0 || combinedResults.rules.length > 0)}}">
    <!-- 关键词结果 -->
    <view class="result-section">
      <view class="section-header">
        <view class="section-bar keyword-bar">
          <text class="section-title">关键词异能</text>
        </view>
        <view class="section-loading" wx:if="{{keywordsLoading}}">
          <text class="loading-dot"></text>
          <text>搜索中...</text>
        </view>
        <text class="section-count" wx:elif="{{combinedResults.keywords.length > 0}}">{{combinedResults.keywords.length}}</text>
      </view>
      <view class="result-list" wx:if="{{!keywordsLoading || combinedResults.keywords.length > 0}}">
        <view class="section-loading-placeholder" wx:if="{{keywordsLoading && combinedResults.keywords.length === 0}}">
          <text class="loading-dot"></text>
          <text>搜索中...</text>
        </view>
        <view class="result-card keyword-card" wx:for="{{combinedResults.keywords}}" wx:key="index" bindtap="viewKeywordDetail" data-keyword="{{item.keyword_name}}">
          <view class="result-header">
            <text class="result-number">{{item.keyword_en}}</text>
            <text class="result-title">{{item.keyword_name}}</text>
          </view>
          <text class="result-content">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 卡牌结果 -->
    <view class="result-section">
      <view class="section-header">
        <view class="section-bar card-bar">
          <text class="section-title">卡牌</text>
        </view>
        <view class="section-loading" wx:if="{{cardsLoading}}">
          <text class="loading-dot"></text>
          <text>搜索中...</text>
        </view>
        <text class="section-count" wx:elif="{{combinedResults.cards.length > 0}}">{{combinedResults.cards.length}}</text>
      </view>
      <view class="result-list card-list" wx:if="{{!cardsLoading || combinedResults.cards.length > 0}}">
        <view class="section-loading-placeholder" wx:if="{{cardsLoading && combinedResults.cards.length === 0}}">
          <text class="loading-dot"></text>
          <text>搜索中...</text>
        </view>
        <view class="card-item" wx:for="{{combinedResults.cards}}" wx:key="index" bindtap="viewCardDetail" data-id="{{item.id}}">
          <view class="card-name">{{item.zhs_name || item.name}}</view>
          <view class="card-type">{{item.type_line}}</view>
        </view>
      </view>
    </view>

    <!-- 规则结果 -->
    <view class="result-section">
      <view class="section-header">
        <view class="section-bar rule-bar">
          <text class="section-title">规则</text>
        </view>
        <view class="section-loading" wx:if="{{rulesLoading}}">
          <text class="loading-dot"></text>
          <text>搜索中...</text>
        </view>
        <text class="section-count" wx:elif="{{combinedResults.rules.length > 0}}">{{combinedResults.rules.length}}</text>
      </view>
      <view class="result-list" wx:if="{{!rulesLoading || combinedResults.rules.length > 0}}">
        <view class="section-loading-placeholder" wx:if="{{rulesLoading && combinedResults.rules.length === 0}}">
          <text class="loading-dot"></text>
          <text>搜索中...</text>
        </view>
        <view class="result-card" wx:for="{{combinedResults.rules}}" wx:key="index" bindtap="viewRuleDetail" data-rule="{{item.rule_number}}">
          <view class="result-header">
            <text class="result-number">{{item.rule_number}}</text>
            <text class="result-title">{{item.rule_title}}</text>
          </view>
          <text class="result-content">{{item.rule_content}}</text>
        </view>
      </view>
    </view>

    <!-- 无结果 -->
    <view class="no-results" wx:if="{{searchDone && combinedResults.keywords.length === 0 && combinedResults.cards.length === 0 && combinedResults.rules.length === 0}}">
      <text class="no-results-icon">🔎</text>
      <text class="no-results-text">未找到与「{{keyword}}」相关的内容</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">搜索中...</text>
  </view>
</view>