<view class="container">
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">Token 列表</text>
  </view>

  <!-- 紧凑搜索栏 -->
  <view class="search-bar">
    <view class="search-icon icon-bg-search"></view>
    <input
      class="search-input"
      placeholder="输入 Token 名称"
      placeholder-class="search-placeholder"
      bindinput="onTokenSearch"
      bindfocus="onSearchFocus"
      bindblur="onSearchBlur"
      bindconfirm="onSearchConfirm"
      value="{{searchQuery}}"
    />
    <view wx:if="{{searchQuery}}" class="search-clear" bindtap="onClearSearch">
      <view class="close-mini icon-bg-close"></view>
    </view>
  </view>

  <text wx:if="{{showHint}}" class="search-hint">支持：中文 / 英文 / 拼音首字母 / 英文首字母</text>

  <!-- 颜色筛选 chips -->
  <scroll-view wx:if="{{!showSearchResults}}" class="color-chips" scroll-x enable-flex>
    <view class="chip {{selectedColorFilter === 'all' ? 'chip-active' : ''}}" data-color="all" bindtap="onFilterColor">全部 {{totalCount}}</view>
    <view class="chip {{selectedColorFilter === 'W' ? 'chip-active chip-W' : ''}}" data-color="W" bindtap="onFilterColor">
      <view class="chip-dot color-W"></view>
      白 {{groupCounts.W || 0}}
    </view>
    <view class="chip {{selectedColorFilter === 'U' ? 'chip-active chip-U' : ''}}" data-color="U" bindtap="onFilterColor">
      <view class="chip-dot color-U"></view>
      蓝 {{groupCounts.U || 0}}
    </view>
    <view class="chip {{selectedColorFilter === 'B' ? 'chip-active chip-B' : ''}}" data-color="B" bindtap="onFilterColor">
      <view class="chip-dot color-B"></view>
      黑 {{groupCounts.B || 0}}
    </view>
    <view class="chip {{selectedColorFilter === 'R' ? 'chip-active chip-R' : ''}}" data-color="R" bindtap="onFilterColor">
      <view class="chip-dot color-R"></view>
      红 {{groupCounts.R || 0}}
    </view>
    <view class="chip {{selectedColorFilter === 'G' ? 'chip-active chip-G' : ''}}" data-color="G" bindtap="onFilterColor">
      <view class="chip-dot color-G"></view>
      绿 {{groupCounts.G || 0}}
    </view>
    <view class="chip {{selectedColorFilter === 'C' ? 'chip-active chip-C' : ''}}" data-color="C" bindtap="onFilterColor">
      <view class="chip-dot color-C"></view>
      无 {{groupCounts.C || 0}}
    </view>
  </scroll-view>

  <!-- 建议下拉 -->
  <view wx:if="{{showSuggestions && filteredSuggestions.length > 0}}" class="suggestions">
    <view class="suggestion-item"
      wx:for="{{filteredSuggestions}}"
      wx:key="enName"
      bindtap="onSelectSuggestion"
      data-token="{{item}}"
    >
      <view class="suggestion-color color-{{item.color}}"></view>
      <view class="suggestion-icon">{{item.icon}}</view>
      <view class="suggestion-info">
        <text class="suggestion-name">{{item.name}}</text>
        <text class="suggestion-en">{{item.enName}}</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{isSearching}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">搜索中...</text>
  </view>

  <!-- 搜索结果 -->
  <view class="results" wx:elif="{{showSearchResults}}">
    <view wx:if="{{searchResults.length === 0}}" class="empty-hint">
      <text>未找到结果</text>
    </view>
    <view class="result-list" wx:else>
      <view class="result-card" wx:for="{{searchResults}}" wx:key="name" bindtap="selectSearchResult" data-item="{{item}}">
        <view class="result-name">{{item.name}}</view>
        <view class="result-meta">{{item.setName || ''}} · {{item.power || '?'}}/{{item.toughness || '?'}}</view>
      </view>
    </view>
  </view>

  <!-- 历史 + 热门 -->
  <view wx:if="{{!searchQuery && !showSearchResults && !showSuggestions}}" class="history-section">
    <view wx:if="{{searchHistory.length > 0}}" class="history-block">
      <text class="block-title">最近搜索</text>
      <view class="history-chips">
        <view class="history-chip" wx:for="{{searchHistory}}" wx:key="*this"
          data-q="{{item}}" bindtap="onHistoryTap">
          <text>{{item}}</text>
          <view class="close-tiny icon-bg-close"></view>
        </view>
        <view class="history-clear" bindtap="onClearHistory">清空</view>
      </view>
    </view>

    <view class="hot-block">
      <text class="block-title">热门 Token</text>
      <view class="hot-list">
        <view class="hot-chip" wx:for="{{hotTokens}}" wx:key="name"
          data-token="{{item}}" bindtap="onSelectSuggestion">
          <view class="hot-color color-{{item.color}}"></view>
          <text>{{item.icon}} {{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 默认按颜色分组列表 -->
  <view class="token-groups" wx:else>
    <view wx:if="{{filteredGroup.tokens.length === 0}}" class="empty-hint">
      <text>该颜色暂无 Token</text>
    </view>
    <view wx:elif="{{selectedColorFilter === 'all'}}" class="group">
      <view wx:for="{{filteredGroup.tokens}}" wx:key="name" wx:for-item="token" class="token-card" bindtap="selectToken" data-token="{{token}}">
        <view class="token-color-stripe color-{{token.color}}"></view>
        <view class="token-icon">{{token.icon}}</view>
        <view class="token-info">
          <view class="token-name">{{token.name}}</view>
          <view class="token-en">{{token.enName}}</view>
        </view>
        <view class="token-stats">{{token.power}}/{{token.toughness}}</view>
      </view>
    </view>
    <view wx:else class="group">
      <view wx:for="{{filteredGroup.tokens}}" wx:key="name" wx:for-item="token" class="token-card" bindtap="selectToken" data-token="{{token}}">
        <view class="token-color-stripe color-{{token.color}}"></view>
        <view class="token-icon">{{token.icon}}</view>
        <view class="token-info">
          <view class="token-name">{{token.name}}</view>
          <view class="token-en">{{token.enName}}</view>
        </view>
        <view class="token-stats">{{token.power}}/{{token.toughness}}</view>
      </view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view class="modal {{showModal ? 'show' : ''}}" wx:if="{{showModal && selectedToken}}" catchtap="closeModal">
    <view class="modal-content" catchtap="noop">
      <!-- Token 卡片展示 -->
      <view class="token-preview color-{{selectedToken.color}}">
        <view class="token-preview-bg">
          <!-- 加载中 -->
          <view class="token-loading" wx:if="{{isLoadingToken}}">
            <text>加载中...</text>
          </view>

          <!-- 无卡图 -->
          <view class="token-no-image" wx:elif="{{tokenCards.length === 0}}">
            <view class="token-preview-icon">{{selectedToken.icon}}</view>
            <view class="token-preview-name">{{selectedToken.name}}</view>
            <view class="token-preview-type">{{selectedToken.colorName}} · {{selectedToken.power}}/{{selectedToken.toughness}}</view>
          </view>

          <!-- 有卡图 -->
          <view class="token-with-image" wx:else>
            <image
              class="token-card-image"
              src="{{tokenCards[selectedCardIndex].image_uris.normal || tokenCards[selectedCardIndex].image_uris.small}}"
              mode="aspectFit"
              bindtap="saveToken"
            />
            <!-- 图片指示器 -->
            <view class="image-indicators" wx:if="{{tokenCards.length > 1}}">
              <view class="indicator {{selectedCardIndex === index ? 'active' : ''}}" wx:for="{{tokenCards}}" wx:key="index"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 图片切换箭头 + 系列选择 -->
      <view class="image-nav" wx:if="{{tokenCards.length > 0}}">
        <view class="nav-arrow left {{selectedCardIndex === 0 ? 'disabled' : ''}}" bindtap="prevCard">&lt;</view>
        <view class="set-picker-trigger" catchtap="toggleSetPicker">
          <text class="nav-count">{{selectedCardIndex + 1}} / {{tokenCards.length}}</text>
          <text class="set-picker-arrow {{showSetPicker ? 'up' : ''}}">▼</text>
        </view>
      </view>

      <!-- 系列下拉选择器 -->
      <view class="set-picker-dropdown {{showSetPicker ? 'show' : ''}}" wx:if="{{availableSets.length > 1 && showSetPicker}}" catchtap="noop">
        <scroll-view class="set-picker-scroll" scroll-y>
          <view
            class="set-picker-item {{selectedSetCode === item.code ? 'active' : ''}}"
            wx:for="{{availableSets}}"
            wx:key="index"
            bindtap="selectSet"
            data-code="{{item.code}}"
          >
            {{item.name}}
          </view>
        </scroll-view>
      </view>

      <!-- Token 信息 -->
      <view class="token-info-section" catchtap="noop">
        <view class="info-row">
          <text class="info-label">名称</text>
          <text class="info-value">{{selectedToken.name}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">系列</text>
          <view class="info-value set-name">
            <text wx:if="{{tokenCards[selectedCardIndex]}}">{{tokenCards[selectedCardIndex].set_name}}</text>
            <text wx:else>-</text>
            <text class="set-arrow {{showSetPicker ? 'up' : ''}}" catchtap="toggleSetPicker">▼</text>
          </view>
        </view>
        <view class="info-row">
          <text class="info-label">颜色</text>
          <text class="info-value">{{selectedToken.colorName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">攻击/防御</text>
          <text class="info-value">{{selectedToken.power}} / {{selectedToken.toughness}}</text>
        </view>
        <view class="info-row" wx:if="{{selectedToken.abilities}}">
          <text class="info-label">异能</text>
          <text class="info-value">{{selectedToken.abilities}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="modal-actions">
        <view class="action-btn copy-btn" bindtap="copyTokenName">
          <text>复制名称</text>
        </view>
        <view class="action-btn save-btn" bindtap="goToGenerate" wx:if="{{tokenCards.length > 0}}">
          <text>生成Token</text>
        </view>
      </view>

      <view class="modal-close modal-close-floating" bindtap="closeModal">
        <view class="close-mini icon-bg-close"></view>
      </view>
    </view>
  </view>

  <!-- 复制品选牌弹窗 -->
  <view class="modal {{showCopyModal ? 'show' : ''}}" wx:if="{{showCopyModal}}" catchtap="closeCopyModal">
    <view class="modal-content copy-modal" catchtap="noop">
      <view class="copy-modal-title">选择要复制的卡牌</view>
      <view class="copy-search-wrapper">
        <input
          class="copy-search-input"
          placeholder="输入卡牌名称（支持中文）"
          placeholder-class="search-placeholder"
          bindinput="onCopySearch"
          value="{{copySearchQuery}}"
          catchtap="noop"
        />
      </view>
      <view class="copy-search-loading" wx:if="{{isCopySearching}}">
        <text>搜索中...</text>
      </view>
      <view class="copy-empty" wx:elif="{{copySearchQuery && !isCopySearching && copySearchResults.length === 0}}">
        <text>未找到卡牌，请换个关键词</text>
      </view>
      <scroll-view class="copy-search-results" scroll-y wx:if="{{copySearchResults.length > 0}}">
        <view
          class="copy-result-item"
          wx:for="{{copySearchResults}}"
          wx:key="index"
          bindtap="selectCopyCard"
          data-card="{{item}}"
        >
          <image class="copy-result-img" src="{{item.zhs_image_uris.small || item.image_uris.small}}" mode="aspectFit" wx:if="{{item.zhs_image_uris || item.image_uris}}" />
          <view class="copy-result-placeholder icon-bg-card" wx:else></view>
          <view class="copy-result-info">
            <text class="copy-result-name">{{item.name}}</text>
            <text class="copy-result-set">{{item.set_name}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="modal-close modal-close-floating" bindtap="closeCopyModal">
        <view class="close-mini icon-bg-close"></view>
      </view>
    </view>
  </view>
</view>