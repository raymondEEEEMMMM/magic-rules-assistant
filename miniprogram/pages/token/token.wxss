/* pages/token/token.wxss */
page { background: var(--bg-page); }
.container { min-height: 100vh; padding: 24rpx 32rpx; }
.nav-bar { display: flex; align-items: center; padding: 16rpx 0 32rpx; background: var(--bg-page); }
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: var(--text-primary); margin-right: 16rpx; }
.back-btn:active { opacity: 0.5; }
.nav-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }

.search-card { background: var(--bg-card); border-radius: 24rpx; box-shadow: var(--shadow-card); padding: 16rpx 20rpx; display: flex; align-items: center; gap: 16rpx; margin-bottom: 32rpx; }
.search-row { flex: 1; display: flex; align-items: center; background: var(--bg-input); border-radius: 20rpx; padding: 16rpx 20rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.5; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.search-placeholder { color: var(--text-muted); }
.search-btn { background: var(--accent-dark); color: var(--text-inverse); border-radius: 20rpx; padding: 16rpx 32rpx; font-size: 28rpx; font-weight: 600; }
.search-btn:active { opacity: 0.7; }

.loading { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.loading-spinner { width: 48rpx; height: 48rpx; border: 4rpx solid var(--bg-input); border-top-color: var(--accent-dark); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 24rpx; color: var(--text-secondary); margin-top: 16rpx; }

.results { padding: 16rpx 0; }
.empty-hint { text-align: center; padding: 60rpx 0; color: var(--text-muted); font-size: 28rpx; }
.result-list { display: flex; flex-direction: column; gap: 16rpx; }
.result-card { background: var(--bg-card); border-radius: 16rpx; box-shadow: var(--shadow-card); padding: 20rpx 24rpx; }
.result-card:active { opacity: 0.7; }
.result-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.result-meta { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

.token-groups { display: flex; flex-direction: column; gap: 32rpx; }
.group { background: var(--bg-card); border-radius: 20rpx; box-shadow: var(--shadow-card); padding: 20rpx 24rpx; }
.group-header { display: flex; align-items: center; gap: 12rpx; padding: 8rpx 0 16rpx; border-bottom: 1rpx solid var(--border-subtle); margin-bottom: 16rpx; }
.color-dot { width: 24rpx; height: 24rpx; border-radius: 50%; background: var(--color-white); border: 1rpx solid var(--border-default); }
.color-dot.color-W { background: var(--color-white); border-color: var(--border-default); }
.color-dot.color-U { background: var(--color-blue); border-color: transparent; }
.color-dot.color-B { background: var(--color-black); border-color: transparent; }
.color-dot.color-R { background: var(--color-red); border-color: transparent; }
.color-dot.color-G { background: var(--color-green); border-color: transparent; }
.color-dot.color-C { background: var(--bg-input); }
.group-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); flex: 1; }
.group-count { font-size: 22rpx; color: var(--text-muted); background: var(--bg-input); padding: 4rpx 12rpx; border-radius: 12rpx; }
.token-list { display: flex; flex-direction: column; gap: 8rpx; }
.token-item { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 12rpx; border-radius: 12rpx; }
.token-item:active { background: var(--bg-input); }
.token-name { font-size: 28rpx; color: var(--text-primary); }
.token-type { font-size: 24rpx; color: var(--text-secondary); font-weight: 600; }

/* Modal 通用 */
.modal { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; display: none; align-items: flex-end; justify-content: center; }
.modal.show { display: flex; }
.modal-content { background: var(--bg-card); border-radius: 32rpx 32rpx 0 0; padding: 32rpx 32rpx 48rpx; width: 100%; max-width: 750rpx; max-height: 88vh; overflow-y: auto; position: relative; box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.15); }
.modal-close-floating { position: absolute; top: 24rpx; right: 24rpx; width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: var(--text-muted); background: var(--bg-input); border-radius: 50%; z-index: 10; }
.modal-close-floating:active { opacity: 0.6; }

/* Token 预览 */
.token-preview { margin: -32rpx -32rpx 24rpx; padding: 32rpx; border-radius: 32rpx 32rpx 0 0; background: var(--bg-input); }
.token-preview-bg { min-height: 320rpx; display: flex; align-items: center; justify-content: center; position: relative; }
.token-loading { font-size: 26rpx; color: var(--text-secondary); padding: 60rpx 0; }
.token-no-image { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; }
.token-preview-icon { font-size: 96rpx; opacity: 0.6; margin-bottom: 16rpx; }
.token-preview-name { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.token-preview-type { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }
.token-with-image { width: 100%; display: flex; flex-direction: column; align-items: center; }
.token-card-image { width: 360rpx; height: 504rpx; border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15); background: var(--bg-input); }
.image-indicators { display: flex; gap: 8rpx; margin-top: 16rpx; }
.indicator { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--text-muted); opacity: 0.4; }
.indicator.active { background: var(--accent-dark); opacity: 1; }

.image-nav { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.nav-arrow { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: var(--text-primary); background: var(--bg-input); border-radius: 50%; }
.nav-arrow.disabled { opacity: 0.3; }
.nav-arrow:active:not(.disabled) { opacity: 0.7; }
.set-picker-trigger { flex: 1; display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 16rpx 24rpx; background: var(--bg-input); border-radius: 16rpx; margin: 0 16rpx; }
.nav-count { font-size: 24rpx; color: var(--text-primary); font-weight: 600; }
.set-picker-arrow { font-size: 20rpx; color: var(--text-secondary); transition: transform 0.2s; }
.set-picker-arrow.up { transform: rotate(180deg); }

.set-picker-dropdown { background: var(--bg-card); border: 1rpx solid var(--border-subtle); border-radius: 16rpx; margin-bottom: 16rpx; max-height: 360rpx; overflow: hidden; display: none; }
.set-picker-dropdown.show { display: block; }
.set-picker-scroll { max-height: 360rpx; }
.set-picker-item { padding: 20rpx 24rpx; font-size: 26rpx; color: var(--text-primary); border-bottom: 1rpx solid var(--border-subtle); }
.set-picker-item:last-child { border-bottom: none; }
.set-picker-item.active { background: var(--accent-gold); color: var(--accent-dark); font-weight: 600; }
.set-picker-item:active { background: var(--bg-input); }

/* Token 信息 */
.token-info-section { margin-top: 16rpx; }
.info-row { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid var(--border-subtle); }
.info-row:last-child { border-bottom: none; }
.info-label { width: 140rpx; font-size: 24rpx; color: var(--text-secondary); flex-shrink: 0; }
.info-value { flex: 1; font-size: 26rpx; color: var(--text-primary); font-weight: 500; display: flex; align-items: center; gap: 8rpx; }
.info-value.set-name { color: var(--accent-dark); }
.set-arrow { font-size: 20rpx; }

/* Modal 操作按钮 */
.modal-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.action-btn { flex: 1; padding: 24rpx 0; border-radius: 20rpx; font-size: 28rpx; font-weight: 600; text-align: center; background: var(--bg-input); color: var(--text-primary); }
.action-btn:active { opacity: 0.7; }
.action-btn.save-btn, .action-btn.copy-btn { background: var(--accent-dark); color: var(--text-inverse); }

/* 复制品弹窗 */
.copy-modal { padding-top: 40rpx; }
.copy-modal-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 24rpx; text-align: center; }
.copy-search-wrapper { margin-bottom: 16rpx; }
.copy-search-input { background: var(--bg-input); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: var(--text-primary); width: 100%; box-sizing: border-box; }
.copy-search-loading { padding: 40rpx 0; text-align: center; color: var(--text-secondary); font-size: 26rpx; }
.copy-empty { padding: 40rpx 0; text-align: center; color: var(--text-muted); font-size: 26rpx; }
.copy-search-results { max-height: 50vh; }
.copy-result-item { display: flex; gap: 16rpx; align-items: center; padding: 16rpx; background: var(--bg-input); border-radius: 16rpx; margin-bottom: 12rpx; }
.copy-result-item:active { opacity: 0.7; }
.copy-result-img { width: 80rpx; height: 112rpx; border-radius: 8rpx; }
.copy-result-placeholder { width: 80rpx; height: 112rpx; border-radius: 8rpx; background: var(--bg-card); display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.copy-result-info { flex: 1; min-width: 0; }
.copy-result-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.copy-result-set { font-size: 22rpx; color: var(--text-secondary); }
