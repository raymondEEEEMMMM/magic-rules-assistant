/* pages/rule/rule.wxss */
.rule-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  text-align: center;
  padding: 60rpx 30rpx 40rpx;
  background: rgba(233, 69, 96, 0.1);
  border-bottom: 2rpx solid rgba(233, 69, 96, 0.3);
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8b8b8b;
  font-style: italic;
}

/* 规则分类 */
.rule-categories {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
  margin: 10rpx;
  min-width: 140rpx;
}

.category-item.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: #e94560;
  transform: scale(1.05);
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #ffffff;
  text-align: center;
}

/* 规则列表 */
.rule-list {
  padding: 0 30rpx;
}

.rule-item {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.rule-item:active {
  transform: scale(0.98);
  opacity: 0.8;
}

/* 规则头部 */
.rule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.03);
}

.rule-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  flex: 1;
}

.rule-arrow {
  font-size: 24rpx;
  color: #e94560;
  margin-left: 20rpx;
}

/* 规则内容 */
.rule-content {
  padding: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(0, 0, 0, 0.2);
}

.rule-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #e0e0e0;
}

/* 示例 */
.rule-example {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(233, 69, 96, 0.1);
  border-left: 4rpx solid #e94560;
  border-radius: 8rpx;
}

.example-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #e94560;
  margin-bottom: 10rpx;
}

.example-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #c0c0c0;
  font-style: italic;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #8b8b8b;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  color: #8b8b8b;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}
