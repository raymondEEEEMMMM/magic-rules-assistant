page {
  background-color: #16213e;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  background: #16213e;
  padding: 0;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 215, 0, 0.15);
  font-size: 32rpx;
  color: #ffd700;
}

.nav-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 日间主题导航栏 */
.nav-bar.nav-bar-light {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-bar.nav-bar-light .back-btn {
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
}

.nav-bar.nav-bar-light .nav-title {
  color: #667eea;
}

.container.page-light {
  background: #f5f5f5;
}

.container.page-light .loading,
.container.page-light .error {
  color: #666;
}

.container.page-light .rule-detail {
  background: #fff;
}

.loading, .error {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #666;
}

.rule-detail {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.rule-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
  padding: 30rpx;
}

.rule-number {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 10rpx;
}

.rule-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.lang-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.lang-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  color: #666;
  font-size: 28rpx;
}

.lang-tab.active {
  color: #1a1a2e;
  border-bottom: 4rpx solid #1a1a2e;
}

.rule-content {
  padding: 30rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.section-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.content-lines {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-line {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  text-align: justify;
}

.bottom-bar {
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.btn-back {
  width: 100%;
  background: #1a1a2e;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
}