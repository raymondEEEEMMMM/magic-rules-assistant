/* pages/feedback/feedback.wxss */
page {
  background-color: #16213e;
  color: #ffffff;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 内容区域 */
.section {
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

/* 类型选择 */
.type-list {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  border: 2rpx solid transparent;
}

.type-item.active {
  background: rgba(255, 215, 0, 0.15);
  color: #ffd700;
  border-color: #ffd700;
}

/* 内容输入 */
.content-input {
  width: 100%;
  min-height: 300rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  box-sizing: border-box;
  line-height: 1.6;
}

.content-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

/* 联系方式输入 */
.contact-input {
  width: 100%;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.contact-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* 提交按钮 */
.submit-btn {
  margin: 40rpx 30rpx 0;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 日间主题 */
.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.page-light .nav-bar {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.page-light .nav-title text {
  color: #667eea;
}

.page-light .back-btn {
  color: #667eea;
}

.page-light .section-title {
  color: #666;
}

.page-light .type-item {
  background: #ffffff;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.page-light .type-item.active {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  border-color: #667eea;
}

.page-light .content-input {
  background: #ffffff;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.page-light .content-input::placeholder {
  color: #999;
}

.page-light .char-count {
  color: #999;
}

.page-light .contact-input {
  background: #ffffff;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.page-light .contact-input::placeholder {
  color: #999;
}