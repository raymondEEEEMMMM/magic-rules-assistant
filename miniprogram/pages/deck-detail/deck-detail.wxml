<view class="container">
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="nav-title">{{deck.name || '套牌详情'}}</text>
  </view>

  <scroll-view class="content" scroll-y wx:if="{{deck}}">
    <view class="deck-content">
      <!-- 卡组信息卡片 -->
      <view class="meta-card">
        <view class="meta-top">
          <text class="meta-format">{{deck.format || 'Standard'}}</text>
          <text class="meta-count">{{deck.totalCards || deck.cardCount || 0}} 张</text>
        </view>
        <view class="meta-bottom" wx:if="{{deck.avgCMC}}">
          <text class="meta-cmc">平均法术力费用 {{deck.avgCMC}}</text>
        </view>
      </view>

      <!-- 指挥官区域 -->
      <view class="section" wx:if="{{commanderInfo}}">
        <text class="section-title">指挥官</text>
        <view class="commander-card">
          <image
            class="commander-image"
            src="{{commanderInfo.image}}"
            mode="aspectSmall"
            wx:if="{{commanderInfo.image}}"
          />
          <view class="commander-info">
            <text class="commander-name">{{commanderInfo.name}}</text>
            <text class="commander-type" wx:if="{{commanderInfo.type_line}}">{{commanderInfo.type_line}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-grid">
        <view class="action-btn" bindtap="goToOdds">
          <text class="action-text">Odds计算</text>
        </view>
        <view class="action-btn" bindtap="shareDeck">
          <text class="action-text">分享卡组</text>
        </view>
        <view class="action-btn" bindtap="exportDeck">
          <text class="action-text">复制导出</text>
        </view>
      </view>

      <!-- 分类卡牌列表 -->
      <block wx:if="{{creatureCards.length > 0}}">
        <view class="section">
          <text class="section-title">生物 ({{creatureCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{creatureCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{sorceryCards.length > 0}}">
        <view class="section">
          <text class="section-title">法术 ({{sorceryCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{sorceryCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{instantCards.length > 0}}">
        <view class="section">
          <text class="section-title">瞬间 ({{instantCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{instantCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{planeswalkerCards.length > 0}}">
        <view class="section">
          <text class="section-title">鹏洛客 ({{planeswalkerCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{planeswalkerCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{enchantmentCards.length > 0}}">
        <view class="section">
          <text class="section-title">结界 ({{enchantmentCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{enchantmentCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{artifactCards.length > 0}}">
        <view class="section">
          <text class="section-title">神器 ({{artifactCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{artifactCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{landCards.length > 0}}">
        <view class="section">
          <text class="section-title">土地 ({{landCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{landCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:if="{{otherCards.length > 0}}">
        <view class="section">
          <text class="section-title">其他 ({{otherCards.length}})</text>
          <view class="cards-list">
            <view class="card-item" wx:for="{{otherCards}}" wx:key="name">
              <text class="card-qty">{{item.count}}×</text>
              <text class="card-name">{{item.name}}</text>
              <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
                <image
                  class="mana-symbol-img"
                  wx:for="{{item.manaSymbols}}"
                  wx:for-item="mana"
                  wx:key="key"
                  src="{{mana.url}}"
                  mode="aspectFit"
                />
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 未分类时显示全部 -->
      <view class="section" wx:if="{{!creatureCards.length && !sorceryCards.length && !instantCards.length && !planeswalkerCards.length && !enchantmentCards.length && !artifactCards.length && !landCards.length && !otherCards.length && mainCards.length > 0}}">
        <text class="section-title">卡牌列表 ({{mainCards.length}})</text>
        <view class="cards-list">
          <view class="card-item" wx:for="{{mainCards}}" wx:key="name">
            <text class="card-qty">{{item.count}}×</text>
            <text class="card-name">{{item.name}}</text>
            <view class="card-mana" wx:if="{{item.manaSymbols && item.manaSymbols.length > 0}}">
              <image
                class="mana-symbol-img"
                wx:for="{{item.manaSymbols}}"
                wx:for-item="mana"
                wx:key="key"
                src="{{mana.url}}"
                mode="aspectFit"
              />
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
