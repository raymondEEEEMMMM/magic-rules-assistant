/* pages/deck-detail/deck-detail.wxss */
page {
  background-color: #16213e;
  height: 100%;
  color: #ffffff;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
}

.nav-bar-light {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.nav-bar-light .back-btn,
.nav-bar-light .nav-title {
  color: #333333;
}

/* 内容区 */
.content {
  flex: 1;
  padding: 20rpx;
}

/* 卡组信息卡片 */
.deck-info-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.deck-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.deck-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  flex: 1;
}

.deck-format-tag {
  font-size: 22rpx;
  color: #ffffff;
  background: #667eea;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.deck-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 指挥官区域 */
.commander-section {
  margin-bottom: 24rpx;
}

.commander-title {
  border-left-color: #ffd700;
}

.commander-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 215, 0, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.15);
}

.commander-card-light {
  background: rgba(212, 160, 23, 0.08);
  border-color: rgba(212, 160, 23, 0.2);
}

.commander-image {
  width: 80rpx;
  height: 112rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.commander-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.commander-info .commander-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
}

.commander-info .commander-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 操作按钮网格 */
.action-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 区域标题 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #ffd700;
}

.type-section-title {
  border-left-color: #667eea;
}

/* 卡牌列表 */
.card-list {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.card-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.card-item:last-child {
  border-bottom: none;
}

.card-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  min-width: 50rpx;
}

.card-name {
  font-size: 28rpx;
  color: #ffffff;
  flex: 1;
}

.card-mana {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-left: auto;
  padding-left: 16rpx;
}

.mana-symbol-img {
  width: 32rpx;
  height: 32rpx;
}

/* Light theme */
.container.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.container.page-light .deck-info-card {
  background: rgba(0, 0, 0, 0.03);
  border-color: rgba(0, 0, 0, 0.05);
}

.container.page-light .deck-name {
  color: #333333;
}

.container.page-light .meta-item {
  color: #666666;
}

.container.page-light .commander-label,
.container.page-light .commander-name {
  color: #d4a017;
}

.container.page-light .commander-card {
  background: rgba(212, 160, 23, 0.08);
  border-color: rgba(212, 160, 23, 0.2);
}

.container.page-light .commander-info .commander-name {
  color: #d4a017;
}

.container.page-light .commander-info .commander-type {
  color: #666;
}

.container.page-light .commander-title {
  color: #333333;
  border-left-color: #d4a017;
}

.container.page-light .action-btn {
  background: rgba(0, 0, 0, 0.03);
  border-color: rgba(0, 0, 0, 0.05);
}

.container.page-light .action-text {
  color: #666666;
}

.container.page-light .card-list {
  background: rgba(0, 0, 0, 0.03);
}

.container.page-light .card-name {
  color: #333333;
}

.container.page-light .card-item {
  border-bottom-color: rgba(0, 0, 0, 0.05);
}

.container.page-light .section-title {
  color: #333333;
  border-left-color: #d4a017;
}

.container.page-light .type-section-title {
  color: #333333;
  border-left-color: #667eea;
}

.container.page-light .commander-section .section-title {
  color: #333333;
}

.container.page-light .deck-format-tag {
  background: #667eea;
  color: #ffffff;
}
