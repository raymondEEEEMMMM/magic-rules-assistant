/* pages/counter/counter.wxss */
page {
  background-color: #16213e;
  height: 100%;
  color: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255, 215, 0, 0.15);
}

.nav-left, .nav-right {
  min-width: 80rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #ffd700;
}

.nav-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
}

.reset-btn {
  font-size: 28rpx;
  color: #ffd700;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ffd700;
  border-radius: 30rpx;
}

/* 控制栏 */
.control-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
}

.format-select {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.format-select .label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.format-select picker {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
}

/* 赛制信息 */
.format-info {
  text-align: center;
  padding: 0 30rpx 20rpx;
}

.format-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.picker-value {
  font-size: 32rpx;
  color: #ffd700;
  font-weight: bold;
}

.coin-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
}

/* 硬币结果 */
.coin-result {
  text-align: center;
  padding: 40rpx;
}

.coin-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
}

.coin-flip {
  animation: flip 0.1s infinite;
}

@keyframes flip {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 玩家区域 */
.players-area {
  flex: 1;
  padding: 30rpx;
  min-height: 600rpx;
  display: flex;
  flex-direction: column;
}

.players-grid-2 {
  flex-direction: column;
  justify-content: center;
  padding: 0 60rpx;
  align-items: stretch;
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.players-spacer {
  height: 100rpx;
  width: 100%;
}

.players-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 60rpx;
}

.players-grid-3 {
  flex-direction: row;
}

.players-grid-4 {
  flex-direction: row;
}

/* 指挥官2x2布局 (旋转90度) */
.commander-grid {
  position: fixed;
  top: 55%;
  left: 55%;
  width: 90vh;
  height: 70vw;
  transform: translate(-50%, -50%) rotate(90deg);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40rpx;
  box-sizing: border-box;
}

.commander-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  flex: 1;
  margin-bottom: 30rpx;
  align-items: center;
}

.commander-row:last-child {
  margin-bottom: 0;
  margin-top: 30rpx;
}

.reset-center-btn {
  position: absolute;
  top: 63%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(255, 215, 0, 0.95);
  color: #1a1a2e;
  font-size: 50rpx;
  font-weight: bold;
  padding: 16rpx;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.commander-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  width: 46%;
}

.commander-player .player-name {
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.commander-player .player-life {
  padding: 20rpx 40rpx;
  margin-bottom: 16rpx;
}

.commander-player .life-value {
  font-size: 72rpx;
}

.commander-player .life-controls {
  gap: 16rpx;
}

.commander-player .life-btn {
  padding: 16rpx 28rpx;
  font-size: 30rpx;
  min-width: 70rpx;
}

/* 单人布局 */
.solo-layout {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
}

.solo-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  padding: 60rpx 80rpx;
}

.solo-player .player-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 30rpx;
}

.solo-player .player-life {
  padding: 40rpx 80rpx;
  margin-bottom: 30rpx;
}

.solo-player .life-value {
  font-size: 120rpx;
}

.solo-player .life-controls {
  gap: 20rpx;
}

.solo-player .life-btn {
  padding: 20rpx 36rpx;
  font-size: 32rpx;
  min-width: 90rpx;
}

/* 玩家卡片 */
.player-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 30rpx;
  flex: 1;
  min-width: 280rpx;
}

.players-grid-2 .player-card {
  flex: 1;
  max-width: 600rpx;
  min-width: 240rpx;
  min-height: 500rpx;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.players-grid-2 .player-life {
  padding: 0;
  background: transparent;
  margin-bottom: 16rpx;
}

.players-grid-2 .life-value {
  font-size: 120rpx;
}

.players-grid-2 .life-controls {
  flex-direction: column;
  gap: 12rpx;
}

.players-grid-2 .life-btn {
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  min-width: 80rpx;
}

.players-grid-2 .life-btn.minus-small,
.players-grid-2 .life-btn.plus-small {
  display: none;
}

.players-grid-4 .player-card {
  min-width: 200rpx;
}

.player-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
  text-align: center;
  margin-bottom: 20rpx;
}

.player-life {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.life-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #4ade80;
  line-height: 1;
}

.life-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.life-low .life-value {
  color: #fbbf24;
}

.life-critical .life-value {
  color: #ef4444;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

/* 生命值控制按钮 */
.life-controls {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.life-btn {
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  min-width: 70rpx;
  text-align: center;
}

.life-btn.minus {
  background: rgba(239, 68, 68, 0.2);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.life-btn.plus {
  background: rgba(74, 222, 128, 0.2);
  color: #4ade80;
  border: 1rpx solid rgba(74, 222, 128, 0.3);
}

.life-btn.minus-small {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.25);
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  min-width: 60rpx;
}

.life-btn.plus-small {
  background: rgba(74, 222, 128, 0.15);
  color: #4ade80;
  border: 1rpx solid rgba(74, 222, 128, 0.25);
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  min-width: 60rpx;
}

/* ==================== */
/* 日间主题 (Light Mode) */
/* ==================== */
.page-light {
  background-color: #f5f5f5;
  color: #333333;
}

.page-light .nav-bar {
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.page-light .nav-title text {
  color: #667eea;
}

.page-light .back-btn {
  color: #667eea;
}

.page-light .reset-btn {
  color: #667eea;
  border-color: #667eea;
}

.page-light .control-bar {
  background: rgba(0, 0, 0, 0.03);
}

.page-light .format-select .label {
  color: #666;
}

.page-light .format-select picker {
  background: rgba(0, 0, 0, 0.05);
}

.page-light .format-desc {
  color: #999;
}

.page-light .picker-value {
  color: #667eea;
}

.page-light .player-card {
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.page-light .player-life {
  background: rgba(0, 0, 0, 0.05);
}

.page-light .life-value {
  color: #22c55e;
}

.page-light .life-low .life-value {
  color: #f59e0b;
}

.page-light .life-critical .life-value {
  color: #ef4444;
}

/* 4人2x2布局 - 日间主题 */
.page-light .commander-player {
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.page-light .commander-player .player-name {
  color: #333;
}

.page-light .commander-player .life-value {
  color: #22c55e;
}

.page-light .commander-player .life-low .life-value {
  color: #f59e0b;
}

.page-light .commander-player .life-critical .life-value {
  color: #ef4444;
}

/* 单人布局 - 日间主题 */
.page-light .solo-player {
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.page-light .solo-player .player-name {
  color: #667eea;
}

.page-light .solo-player .life-value {
  color: #22c55e;
}

.page-light .solo-player .life-low .life-value {
  color: #f59e0b;
}

.page-light .solo-player .life-critical .life-value {
  color: #ef4444;
}

/* Mana Bar */
.mana-section {
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

.mana-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.mana-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
}

.mana-toggle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.mana-content {
  padding-top: 20rpx;
}

.mana-row {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mana-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.mana-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.mana-icon {
  width: 100%;
  height: 100%;
}

.mana-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.mana-controls {
  display: flex;
  gap: 8rpx;
}

.mana-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  min-width: 50rpx;
  text-align: center;
}

.mana-btn.minus {
  background: rgba(239, 68, 68, 0.2);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.mana-btn.plus {
  background: rgba(74, 222, 128, 0.2);
  color: #4ade80;
  border: 1rpx solid rgba(74, 222, 128, 0.3);
}

.mana-reset-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 日间主题 - Mana Bar */
.page-light .mana-section {
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.page-light .mana-header {
  border-bottom-color: rgba(0, 0, 0, 0.1);
}

.page-light .mana-title {
  color: #667eea;
}

.page-light .mana-toggle {
  color: rgba(0, 0, 0, 0.4);
}

.page-light .mana-value {
  color: #333;
}

.page-light .mana-reset-btn {
  background: rgba(0, 0, 0, 0.05);
  color: #666;
}